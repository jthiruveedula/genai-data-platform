---
import BaseLayout from "../layouts/BaseLayout.astro";
import { CLOUDS, MODULES } from "../data/modules";
import { flavor as gcp } from "../data/flavors/gcp";
import { flavor as aws } from "../data/flavors/aws";
import { flavor as azure } from "../data/flavors/azure";
import { flavor as oss } from "../data/flavors/oss";
import { buildMatrixRows } from "../lib/matrix";

const base = import.meta.env.BASE_URL;

const flavorsByCloud = { gcp, aws, azure, oss };
const cloudIds = CLOUDS.map((c) => c.id);
const rows = buildMatrixRows(MODULES, flavorsByCloud, cloudIds);
const stageCount = MODULES.length;
---

<BaseLayout title="Service equivalence matrix">
  <article>
    <header class="matrix-hero">
      <div class="hero-meta">
        <span class="chip mono">[ {CLOUDS.length} FLAVORS ]</span>
        <span class="chip mono">[ {stageCount} STAGES ]</span>
      </div>
      <h1>Service equivalence matrix</h1>
      <p class="intro">
        Every pipeline stage, mapped across all four flavors — GCP, AWS, Azure, and the OSS/self-hosted stack. Switch
        the active cloud in the navbar and its column re-highlights below, so you can trace one flavor's path through
        the whole curriculum at a glance. Click a column header to sort by that cloud's primary service; click
        "Stage" to toggle between pipeline order and alphabetical order.
      </p>
    </header>

    <div class="matrix-scroll" role="region" aria-label="Service equivalence matrix, scrollable">
      <table class="matrix-table" data-matrix-table>
        <caption class="visually-hidden">
          Service equivalence matrix: one row per curriculum module, one column per cloud flavor, showing which
          services and storage each flavor uses for that module. Column and row headers are sortable buttons.
        </caption>
        <thead>
          <tr>
            <th scope="col" data-sort-key="stage" aria-sort="none">
              <button type="button" class="sort-btn" data-sort-button="stage">
                Stage
                <span class="sort-indicator" data-sort-indicator="stage" aria-hidden="true"></span>
              </button>
            </th>
            {
              CLOUDS.map((cloud) => (
                <th scope="col" data-cloud={cloud.id} data-sort-key={cloud.id} aria-sort="none">
                  <button type="button" class="sort-btn" data-sort-button={cloud.id}>
                    {cloud.label}
                    <span class="sort-indicator" data-sort-indicator={cloud.id} aria-hidden="true" />
                  </button>
                </th>
              ))
            }
          </tr>
        </thead>
        <tbody data-matrix-body>
          {
            rows.map((row) => (
              <tr
                data-row-id={row.id}
                data-row-order={row.order}
                data-row-title={row.title}
                data-first-service={JSON.stringify(row.firstService)}
              >
                <th scope="row">
                  <a href={`${base}modules/${row.id}/`} class="stage-link">
                    <span class="chip mono stage-order">{row.orderLabel}</span>
                    <span class="stage-title">{row.title}</span>
                  </a>
                </th>
                {CLOUDS.map((cloud) => {
                  const cell = row.cells[cloud.id];
                  return (
                    <td data-cloud={cloud.id}>
                      {cell ? (
                        <div class="cell-content">
                          <ul class="service-list">
                            {cell.services.map((service) => (
                              <li class="chip service-chip">{service}</li>
                            ))}
                          </ul>
                          <p class="storage-line">{cell.storage}</p>
                        </div>
                      ) : (
                        <span class="no-entry">
                          {"—"}
                          <span class="visually-hidden">No entry for this flavor</span>
                        </span>
                      )}
                    </td>
                  );
                })}
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </article>

  <script>
    import {
      ariaSortFor,
      compareRows,
      cycleColumnSort,
      indicatorFor,
      INITIAL_SORT_STATE,
      toggleStageSort,
      type SortState,
    } from "../lib/matrix";
    import type { CloudId } from "../data/modules";

    const CLOUD_IDS: CloudId[] = ["gcp", "aws", "azure", "oss"];

    function setupMatrixSort() {
      const table = document.querySelector<HTMLTableElement>("[data-matrix-table]");
      if (!table || table.dataset.matrixBound === "true") return;
      table.dataset.matrixBound = "true";

      const tbody = table.querySelector<HTMLTableSectionElement>("[data-matrix-body]");
      if (!tbody) return;

      let state: SortState = INITIAL_SORT_STATE;
      const originalRows = Array.from(tbody.querySelectorAll<HTMLTableRowElement>("tr"));
      const rowById = new Map(originalRows.map((tr) => [tr.dataset.rowId ?? "", tr]));

      function render() {
        const headerStage = table!.querySelector<HTMLTableCellElement>('th[data-sort-key="stage"]');
        if (headerStage) {
          headerStage.setAttribute("aria-sort", ariaSortFor(state, null));
          const indicator = headerStage.querySelector<HTMLElement>('[data-sort-indicator="stage"]');
          if (indicator) indicator.textContent = indicatorFor(state, null);
        }
        for (const cloud of CLOUD_IDS) {
          const th = table!.querySelector<HTMLTableCellElement>(`th[data-sort-key="${cloud}"]`);
          if (th) {
            th.setAttribute("aria-sort", ariaSortFor(state, cloud));
            const indicator = th.querySelector<HTMLElement>(`[data-sort-indicator="${cloud}"]`);
            if (indicator) indicator.textContent = indicatorFor(state, cloud);
          }
        }

        // Re-derive MatrixRow-shaped objects from the DOM order/state we
        // already computed server-side isn't available client-side, so we
        // sort the actual <tr> elements using the same comparator by reading
        // back the minimal fields we stashed as data attributes.
        const rowsData = originalRows.map((tr) => ({
          id: tr.dataset.rowId ?? "",
          order: Number(tr.dataset.rowOrder ?? 0),
          title: tr.dataset.rowTitle ?? "",
          cells: {} as any,
          firstService: JSON.parse(tr.dataset.firstService ?? "{}"),
          orderLabel: "",
        }));

        const sorted = rowsData.slice().sort((a, b) => compareRows(a as any, b as any, state));
        for (const row of sorted) {
          const tr = rowById.get(row.id);
          if (tr) tbody!.appendChild(tr);
        }
      }

      table.addEventListener("click", (event) => {
        const button = (event.target as HTMLElement).closest<HTMLButtonElement>("[data-sort-button]");
        if (!button) return;
        const key = button.dataset.sortButton;
        if (!key) return;
        if (key === "stage") {
          state = toggleStageSort(state);
        } else if ((CLOUD_IDS as string[]).includes(key)) {
          state = cycleColumnSort(state, key as CloudId);
        }
        render();
      });

      render();
    }

    setupMatrixSort();
    document.addEventListener("astro:page-load", setupMatrixSort);
  </script>
</BaseLayout>

<style>
  .matrix-hero {
    padding-bottom: 1.5rem;
    margin-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
  }

  .hero-meta {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 0.85rem;
  }

  h1 {
    margin: 0 0 0.85rem;
    font-size: clamp(1.9rem, 4vw, 2.6rem);
    font-weight: 800;
    letter-spacing: -0.02em;
  }

  .intro {
    max-width: 48rem;
    color: var(--text-secondary);
    line-height: 1.6;
    font-size: 1.05rem;
  }

  .matrix-scroll {
    overflow-x: auto;
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }

  .matrix-table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    font-size: 0.9rem;
  }

  .matrix-table th,
  .matrix-table td {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--border);
    text-align: left;
    vertical-align: top;
  }

  .matrix-table thead th {
    background: var(--bg);
    position: sticky;
    top: 0;
    z-index: 2;
    border-bottom: 1px solid var(--border);
  }

  .matrix-table tbody th[scope="row"] {
    position: sticky;
    left: 0;
    background: var(--bg);
    z-index: 1;
    min-width: 14rem;
  }

  .matrix-table thead th:first-child {
    left: 0;
    z-index: 3;
  }

  .sort-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: none;
    border: none;
    color: var(--text);
    font: inherit;
    font-weight: 700;
    cursor: pointer;
    padding: 0.15rem 0.25rem;
    border-radius: calc(var(--radius) / 2);
  }

  .sort-btn:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .sort-indicator {
    font-size: 0.75rem;
    color: var(--accent-text, var(--accent));
  }

  .stage-link {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--text);
    text-decoration: none;
    font-weight: 700;
  }

  .stage-link:hover .stage-title {
    text-decoration: underline;
  }

  .stage-order {
    flex-shrink: 0;
  }

  .cell-content {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .service-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .service-chip {
    font-size: 0.7rem;
  }

  .storage-line {
    margin: 0;
    color: var(--text-secondary);
    font-size: 0.78rem;
  }

  .no-entry {
    color: var(--text-secondary);
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    margin: -1px;
    padding: 0;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* Active-flavor column highlight — pure CSS driven by the html[data-cloud]
     attribute the cloud selector sets, so it stays in sync without JS here. */
  :global(html[data-cloud="gcp"]) td[data-cloud="gcp"],
  :global(html[data-cloud="gcp"]) th[data-cloud="gcp"] {
    background: color-mix(in srgb, var(--accent) 12%, transparent);
    box-shadow: inset 2px 0 0 var(--accent);
  }
  :global(html[data-cloud="gcp"]) th[data-cloud="gcp"] .sort-btn {
    color: var(--accent-text, var(--accent));
  }

  :global(html[data-cloud="aws"]) td[data-cloud="aws"],
  :global(html[data-cloud="aws"]) th[data-cloud="aws"] {
    background: color-mix(in srgb, var(--accent) 12%, transparent);
    box-shadow: inset 2px 0 0 var(--accent);
  }
  :global(html[data-cloud="aws"]) th[data-cloud="aws"] .sort-btn {
    color: var(--accent-text, var(--accent));
  }

  :global(html[data-cloud="azure"]) td[data-cloud="azure"],
  :global(html[data-cloud="azure"]) th[data-cloud="azure"] {
    background: color-mix(in srgb, var(--accent) 12%, transparent);
    box-shadow: inset 2px 0 0 var(--accent);
  }
  :global(html[data-cloud="azure"]) th[data-cloud="azure"] .sort-btn {
    color: var(--accent-text, var(--accent));
  }

  :global(html[data-cloud="oss"]) td[data-cloud="oss"],
  :global(html[data-cloud="oss"]) th[data-cloud="oss"] {
    background: color-mix(in srgb, var(--accent) 12%, transparent);
    box-shadow: inset 2px 0 0 var(--accent);
  }
  :global(html[data-cloud="oss"]) th[data-cloud="oss"] .sort-btn {
    color: var(--accent-text, var(--accent));
  }
</style>
