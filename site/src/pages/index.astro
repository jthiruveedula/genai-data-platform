---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroScene from "../components/home/HeroScene.astro";
import ArchitectureStory from "../components/home/ArchitectureStory.astro";
import CloudFlavorDeck from "../components/home/CloudFlavorDeck.astro";
import CurriculumJourney from "../components/home/CurriculumJourney.astro";
import CostConsole from "../components/home/CostConsole.astro";
import WhyItMatters from "../components/home/WhyItMatters.astro";
import FinalCTA from "../components/home/FinalCTA.astro";
---

<BaseLayout
  title="Home"
  description="A cinematic, interactive curriculum for building GenAI data platforms on GCP, AWS, Azure, or pure open source."
  fullBleed
>
  <HeroScene />
  <ArchitectureStory />
  <CloudFlavorDeck />
  <CurriculumJourney />
  <CostConsole />
  <WhyItMatters />
  <FinalCTA />
</BaseLayout>

<style is:global>
  /* Homepage scene rhythm: every scene manages its own internal layout, the
     page provides the shared width + vertical cadence. Scenes alternate
     between --bg and --bg-deep via their own backgrounds. */
  .main--full-bleed > section {
    padding: 6rem 0;
  }

  .main--full-bleed .scene-inner {
    max-width: 72rem;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  @media (max-width: 768px) {
    .main--full-bleed > section {
      padding: 4rem 0;
    }
  }
</style>
