---
import { MODULES } from "../../data/modules";

interface Props {
  moduleId: string;
}

const { moduleId } = Astro.props;
const base = import.meta.env.BASE_URL;

const mod = MODULES.find((m) => m.id === moduleId);
if (!mod) throw new Error(`ModuleHero: unknown module id "${moduleId}"`);

const LANE_LABEL: Record<string, string> = {
  beginner: "CORE",
  intermediate: "DEEPEN",
  advanced: "SCALE",
};

const orderLabel = String(mod.order).padStart(2, "0");
---

<header class="module-hero">
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href={`${base}#curriculum`}>Curriculum</a>
    <span class="crumb-sep" aria-hidden="true">/</span>
    <span class="crumb-current">Module {orderLabel}</span>
  </nav>

  <div class="hero-meta">
    <span class="chip chip--accent">{LANE_LABEL[mod.path]}</span>
    <span class="chip mono">MODULE {orderLabel}</span>
  </div>

  <h1 class="module-title">{mod.title}</h1>

  <div class="module-intro">
    <slot />
  </div>
</header>

<style>
  .module-hero {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.85rem;
    padding-bottom: 1.75rem;
    margin-bottom: 1.75rem;
    border-bottom: 1px solid var(--border);
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-secondary);
  }

  .breadcrumb a {
    color: var(--text-secondary);
    text-decoration: none;
  }

  .breadcrumb a:hover {
    color: var(--accent-text, var(--accent));
    text-decoration: underline;
  }

  .crumb-sep {
    color: var(--border);
  }

  .crumb-current {
    color: var(--text);
  }

  .hero-meta {
    display: flex;
    gap: 0.5rem;
  }

  .module-title {
    margin: 0;
    font-size: clamp(1.9rem, 4vw, 2.6rem);
    font-weight: 800;
    letter-spacing: -0.02em;
  }

  .module-intro :global(p) {
    margin: 0;
    max-width: 44rem;
    color: var(--text-secondary);
    line-height: 1.6;
    font-size: 1.05rem;
  }
</style>
