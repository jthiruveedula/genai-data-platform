---
/* Hallmark · pre-emit critique: P4 H4 E4 S4 R5 V4 */
// "In the field" aside — one real, publicly cited customer case study per
// module, swapped by cloud (company, story, and source all change with the
// selection, not just an accent color or tagline). Sits right after the
// module hero, before the conceptual sections, so the story frames what
// follows rather than summarizing it.
import { CASE_STUDIES, neutralCaseStudySummary } from "../../data/scenarios";
import { MODULE_CLOUD_SERVICE } from "../../data/moduleFlows";

interface Props {
  moduleId: string;
}

const { moduleId } = Astro.props;
const entry = CASE_STUDIES[moduleId];
if (!entry) throw new Error(`ModuleScenario: no case study registered for module "${moduleId}"`);
const cloudService = MODULE_CLOUD_SERVICE[moduleId];
const neutral = neutralCaseStudySummary(entry);
const clouds = ["gcp", "aws", "azure", "oss"] as const;
---

<aside class="module-scenario" aria-label="In the field: real customer case study">
  <p class="scenario-kicker">IN THE FIELD <span class="scenario-disclaimer">— real, publicly published customer stories, cited below</span></p>
  {
    cloudService && (
      <p class="scenario-cloud-line mono">
        ON THIS CLOUD:{" "}
        <span class="cloud-swap">
          <span data-for="neutral">{cloudService.neutral}</span>
          <span data-for="gcp">{cloudService.gcp}</span>
          <span data-for="aws">{cloudService.aws}</span>
          <span data-for="azure">{cloudService.azure}</span>
          <span data-for="oss">{cloudService.oss}</span>
        </span>
      </p>
    )
  }
  <div class="scenario-beat cloud-swap">
    <div data-for="neutral" class="scenario-neutral">{neutral}</div>
    {
      clouds.map((cloud) => {
        const story = entry[cloud];
        return (
          <div data-for={cloud} class="scenario-story">
            <p class="scenario-company">
              <span class="chip chip--accent">{story.industry}</span>
              <strong>{story.company}</strong>
              {story.stretch && <span class="chip chip--pending" title="Closest publicly available real match — the vignette explains why">CLOSEST PUBLISHED MATCH</span>}
            </p>
            <p class="scenario-vignette">{story.vignette}</p>
            <p class="scenario-impact">
              <span class="scenario-impact-problem">{story.impact.problem}</span>
              <span class="scenario-impact-arrow" aria-hidden="true">→</span>
              <span class="scenario-impact-fix">{story.impact.fix}</span>
            </p>
            <p class="scenario-source">
              <a href={story.sourceUrl} target="_blank" rel="noopener noreferrer">
                Source ↗
              </a>
            </p>
          </div>
        );
      })
    }
  </div>
</aside>

<style>
  .module-scenario {
    margin: 2rem 0 2.5rem;
    padding: 1.4rem 1.6rem 1.6rem;
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent);
    border-radius: var(--radius);
    background: var(--bg-raised);
  }

  .scenario-kicker {
    margin: 0 0 1.1rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    color: var(--accent-text, var(--accent));
    text-transform: uppercase;
  }

  .scenario-disclaimer {
    color: var(--text-secondary);
    letter-spacing: normal;
    text-transform: none;
  }

  .scenario-cloud-line {
    margin: 0 0 1.1rem;
    font-size: 0.68rem;
    letter-spacing: 0.04em;
    color: var(--text-secondary);
  }

  .scenario-cloud-line .cloud-swap {
    color: var(--accent-text, var(--accent));
    font-weight: 600;
  }

  /* The shared .cloud-swap utility (base.css) sets every [data-for] to
     display:none, and the active one to display:inline — fine for short
     labels, but this beat's active variant is a full block (company line +
     vignette + impact + source), so the active state is overridden to
     display:block here. Astro's per-component scoping (an extra attribute
     selector on every selector below) gives this the specificity edge over
     the shared inline rule without touching base.css's site-wide behavior. */
  .scenario-beat > [data-for] {
    max-width: 44rem;
  }

  :root:not([data-cloud]) .scenario-beat > [data-for="neutral"],
  :root[data-cloud="gcp"] .scenario-beat > [data-for="gcp"],
  :root[data-cloud="aws"] .scenario-beat > [data-for="aws"],
  :root[data-cloud="azure"] .scenario-beat > [data-for="azure"],
  :root[data-cloud="oss"] .scenario-beat > [data-for="oss"] {
    display: block;
  }

  .scenario-neutral {
    color: var(--text-secondary);
    line-height: 1.55;
    font-size: 0.92rem;
  }

  .scenario-company {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.5rem;
    margin: 0 0 0.5rem;
    font-size: 0.9rem;
  }

  .scenario-vignette {
    margin: 0 0 0.75rem;
    color: var(--text-secondary);
    line-height: 1.55;
    font-size: 0.92rem;
  }

  .scenario-impact {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.4rem;
    margin: 0 0 0.6rem;
    padding-top: 0.6rem;
    border-top: 1px dashed var(--border);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.01em;
  }

  .scenario-impact-problem {
    color: var(--text-secondary);
  }

  .scenario-impact-arrow {
    color: var(--accent);
  }

  .scenario-impact-fix {
    color: var(--text);
    font-weight: 600;
  }

  .scenario-source {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.7rem;
  }

  .scenario-source a {
    color: var(--text-secondary);
  }

  .scenario-source a:hover {
    color: var(--accent-text, var(--accent));
  }

  @media (max-width: 640px) {
    .module-scenario {
      padding: 1.15rem 1.15rem 1.3rem;
    }
  }
</style>
