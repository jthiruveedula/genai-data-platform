---
import { QUIZZES } from "../../data/quizzes";

interface Props {
  moduleId: string;
}

const { moduleId } = Astro.props;
const questions = QUIZZES[moduleId];
if (!questions) throw new Error(`ModuleQuiz: no quiz registered for module "${moduleId}"`);
---

<section class="module-quiz glass-panel" data-module-quiz data-module-id={moduleId} aria-labelledby={`quiz-heading-${moduleId}`}>
  <header class="quiz-head">
    <p class="section-kicker">CHECKPOINT</p>
    <h2 class="quiz-title" id={`quiz-heading-${moduleId}`}>Test what stuck.</h2>
    <p class="quiz-lede">
      {questions.length} questions, scored instantly, nothing sent anywhere — your last score is remembered on this
      device.
    </p>
    <p class="chip mono quiz-last-score" data-quiz-last-score hidden></p>
  </header>

  <form class="quiz-form" data-quiz-form novalidate>
    {
      questions.map((q, qi) => (
        <fieldset class="quiz-question" data-quiz-question={qi}>
          <legend class="quiz-question-text">
            <span class="quiz-question-number mono">Q{qi + 1}</span>
            {q.question}
          </legend>
          <div class="quiz-options" role="radiogroup">
            {q.options.map((option, oi) => (
              <label class="quiz-option" data-option-index={oi}>
                <input type="radio" name={`q${qi}`} value={oi} required />
                <span>{option}</span>
              </label>
            ))}
          </div>
          <p class="quiz-feedback" data-quiz-feedback hidden />
        </fieldset>
      ))
    }

    <div class="quiz-actions">
      <button type="submit" class="btn btn-primary" data-quiz-submit>
        Check answers
      </button>
      <button type="button" class="btn btn-ghost" data-quiz-retake hidden>
        Retake quiz
      </button>
      <p class="quiz-result chip chip--accent" data-quiz-result aria-live="polite" hidden></p>
    </div>
  </form>
</section>

<script>
  import { QUIZZES } from "../../data/quizzes";

  function storageKey(moduleId: string) {
    return `gdp.quiz.${moduleId}`;
  }

  function loadLastScore(moduleId: string): { score: number; total: number } | null {
    try {
      const raw = localStorage.getItem(storageKey(moduleId));
      if (!raw) return null;
      const parsed = JSON.parse(raw);
      if (typeof parsed.score === "number" && typeof parsed.total === "number") return parsed;
      return null;
    } catch {
      return null;
    }
  }

  function saveScore(moduleId: string, score: number, total: number) {
    try {
      localStorage.setItem(storageKey(moduleId), JSON.stringify({ score, total, completedAt: Date.now() }));
    } catch {
      // localStorage unavailable (e.g. private mode) — score just won't persist across visits.
    }
  }

  function setup() {
    document.querySelectorAll<HTMLElement>("[data-module-quiz]").forEach((root) => {
      if (root.dataset.quizBound) return;
      root.dataset.quizBound = "true";

      const moduleId = root.dataset.moduleId!;
      const questions = QUIZZES[moduleId];
      const form = root.querySelector<HTMLFormElement>("[data-quiz-form]");
      const submitBtn = root.querySelector<HTMLButtonElement>("[data-quiz-submit]");
      const retakeBtn = root.querySelector<HTMLButtonElement>("[data-quiz-retake]");
      const resultEl = root.querySelector<HTMLElement>("[data-quiz-result]");
      const lastScoreEl = root.querySelector<HTMLElement>("[data-quiz-last-score]");
      if (!form || !questions) return;

      const last = loadLastScore(moduleId);
      if (last && lastScoreEl) {
        lastScoreEl.textContent = `LAST SCORE ${last.score}/${last.total}`;
        lastScoreEl.hidden = false;
      }

      function fieldsetFor(qi: number) {
        return root.querySelector<HTMLFieldSetElement>(`[data-quiz-question="${qi}"]`);
      }

      function resetQuiz() {
        form!.reset();
        questions.forEach((_, qi) => {
          const fs = fieldsetFor(qi);
          fs?.classList.remove("is-correct", "is-incorrect");
          fs?.querySelectorAll("[data-option-index]").forEach((el) => el.classList.remove("is-the-answer"));
          const feedback = fs?.querySelector<HTMLElement>("[data-quiz-feedback]");
          if (feedback) {
            feedback.hidden = true;
            feedback.textContent = "";
          }
          fs?.querySelectorAll("input").forEach((input) => (input.disabled = false));
        });
        if (resultEl) {
          resultEl.hidden = true;
          resultEl.textContent = "";
        }
        submitBtn!.hidden = false;
        retakeBtn!.hidden = true;
      }

      form.addEventListener("submit", (e) => {
        e.preventDefault();

        // Every radio group carries `required`, so an unanswered question
        // fails native constraint validation — bail out here (showing the
        // browser's built-in "please select one of these options" prompt)
        // rather than scoring it as simply wrong, which would reveal the
        // correct answer for a question the learner never attempted.
        if (!form!.checkValidity()) {
          form!.reportValidity();
          return;
        }

        let score = 0;

        questions.forEach((q, qi) => {
          const fs = fieldsetFor(qi);
          const feedback = fs?.querySelector<HTMLElement>("[data-quiz-feedback]");
          const selected = fs?.querySelector<HTMLInputElement>(`input[name="q${qi}"]:checked`);
          const isCorrect = selected ? Number(selected.value) === q.correctIndex : false;

          fs?.classList.toggle("is-correct", isCorrect);
          fs?.classList.toggle("is-incorrect", !isCorrect);
          fs?.querySelectorAll("input").forEach((input) => (input.disabled = true));

          if (!isCorrect) {
            fs?.querySelector(`[data-option-index="${q.correctIndex}"]`)?.classList.add("is-the-answer");
          }

          if (feedback) {
            feedback.hidden = false;
            feedback.textContent = isCorrect ? "Correct." : `Not quite — ${q.explanation}`;
          }

          if (isCorrect) score++;
        });

        saveScore(moduleId, score, questions.length);

        if (resultEl) {
          resultEl.hidden = false;
          resultEl.textContent = `[ ${score >= questions.length * 0.7 ? "PASS" : "SCORE"} ${score}/${questions.length} ]`;
        }
        submitBtn!.hidden = true;
        retakeBtn!.hidden = false;
        retakeBtn!.focus();
      });

      retakeBtn?.addEventListener("click", resetQuiz);
    });
  }

  setup();
  document.addEventListener("astro:page-load", setup);
</script>

<style>
  .module-quiz {
    margin-top: 3rem;
    padding: 1.75rem 2rem 2rem;
  }

  .quiz-head {
    margin-bottom: 1.5rem;
  }

  .quiz-title {
    font-size: 1.4rem;
    font-weight: 800;
    letter-spacing: -0.01em;
    margin: 0.5rem 0 0.5rem;
  }

  .quiz-lede {
    margin: 0 0 0.75rem;
    color: var(--text-secondary);
  }

  .quiz-last-score {
    width: fit-content;
  }

  .quiz-form {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  .quiz-question {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.1rem 1.25rem 1.25rem;
    margin: 0;
    transition: border-color var(--duration-micro) var(--ease-out);
  }

  .quiz-question-text {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    font-weight: 600;
    padding: 0;
    margin-bottom: 0.85rem;
  }

  .quiz-question-number {
    color: var(--accent-text, var(--accent));
    font-size: 0.8rem;
  }

  .quiz-options {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .quiz-option {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    min-height: 44px;
    padding: 0.5rem 0.7rem;
    border-radius: calc(var(--radius) * 0.75);
    cursor: pointer;
    transition: background-color var(--duration-micro) var(--ease-out);
  }

  .quiz-option:hover {
    background: var(--bg-raised);
  }

  /* Marks the selected option via the label, not just the native radio dot —
     browsers render disabled radios at low contrast (barely visible on a
     dark surface), and inputs are disabled the moment a question is
     scored, so without this the learner can't tell which answer they
     picked once feedback appears. */
  .quiz-option:has(input:checked) {
    background: var(--bg-raised);
    box-shadow: inset 0 0 0 1.5px var(--border);
  }

  .quiz-question.is-correct .quiz-option:has(input:checked) {
    box-shadow: inset 0 0 0 1.5px var(--accent);
  }

  .quiz-question.is-incorrect .quiz-option:has(input:checked) {
    box-shadow: inset 0 0 0 1.5px var(--text-secondary);
  }

  .quiz-option input {
    margin-top: 0.25rem;
    accent-color: var(--accent);
  }

  /* Marks the correct option when the learner picked the wrong one — shown
     alongside the explanation text so the right answer is visible, not
     just described. */
  .quiz-option.is-the-answer {
    box-shadow: inset 0 0 0 1.5px var(--accent);
  }

  .quiz-option.is-the-answer::after {
    content: "correct answer";
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--accent-text, var(--accent));
  }

  .quiz-question.is-correct {
    border-color: var(--accent);
  }

  .quiz-question.is-incorrect {
    border-color: color-mix(in srgb, var(--text-secondary) 60%, transparent);
  }

  .quiz-feedback {
    margin: 0.85rem 0 0;
    font-size: 0.88rem;
    color: var(--text-secondary);
  }

  .quiz-question.is-correct .quiz-feedback {
    color: var(--accent-text, var(--accent));
  }

  .quiz-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .quiz-result {
    font-size: 0.85rem;
  }
</style>
