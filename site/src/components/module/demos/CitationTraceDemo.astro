---
// Bespoke concept demo for Module 25 (Serving) — a retrieved chunk's phrase
// traced, literally, into the final answer's citation marker. Makes
// "grounded" a visible line you can follow instead of a claim.
---

<figure class="concept-demo citation-demo" data-citation-demo aria-label="A retrieved chunk's phrase traced into the final cited answer">
  <figcaption class="concept-demo-label mono">[ SEE IT: THE CITATION, TRACED ]</figcaption>

  <div class="citation-chunk" data-citation-item="chunk">
    <span class="citation-chunk-label mono">RETRIEVED — doc_id: policy_HO3, chunk 12</span>
    <p class="citation-chunk-text">
      Coverage renews annually
      <span class="citation-highlight" data-citation-item="highlight">unless written notice is submitted within thirty days</span>
      of the renewal date.
    </p>
  </div>

  <div class="citation-arrow mono" data-citation-item="arrow">↓ assembled into the prompt, with source attached</div>

  <div class="citation-answer" data-citation-item="answer">
    <span class="citation-answer-label mono">GENERATED ANSWER</span>
    <p class="citation-answer-text">
      Your policy renews automatically
      <span class="citation-highlight" data-citation-item="highlight2">unless you submit written notice within thirty days</span>
      of your renewal date.
      <span class="citation-marker" data-citation-item="marker">[1]</span>
    </p>
    <p class="citation-footnote mono">[1] policy_HO3, chunk 12 — <a href="#">view source</a></p>
  </div>
</figure>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  let ctx: gsap.Context | undefined;

  function setup() {
    const rootEl = document.querySelector<HTMLElement>("[data-citation-demo]");
    if (!rootEl) return;
    ctx?.revert();
    ctx = gsap.context(() => {
      const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const items = gsap.utils.toArray<HTMLElement>("[data-citation-item]", rootEl);
      const marker = rootEl.querySelector<HTMLElement>('[data-citation-item="marker"]');

      if (reduced) {
        gsap.set(items, { autoAlpha: 1, y: 0 });
        return;
      }

      gsap.set(items, { autoAlpha: 0, y: 8 });
      const tl = gsap.timeline({ scrollTrigger: { trigger: rootEl, start: "top 85%", once: true } });
      tl.to('[data-citation-item="chunk"]', { autoAlpha: 1, y: 0, duration: 0.35 })
        .to('[data-citation-item="highlight"]', { autoAlpha: 1, y: 0, duration: 0.3 }, "+=0.1")
        .to('[data-citation-item="arrow"]', { autoAlpha: 1, y: 0, duration: 0.3 }, "+=0.15")
        .to('[data-citation-item="answer"]', { autoAlpha: 1, y: 0, duration: 0.35 }, "+=0.1")
        .to('[data-citation-item="highlight2"]', { autoAlpha: 1, y: 0, duration: 0.3 }, "+=0.1")
        .to(marker, { autoAlpha: 1, y: 0, scale: 1.3, duration: 0.25, ease: "back.out(2)", yoyo: true, repeat: 1 }, "+=0.05");
    }, rootEl);
  }

  setup();
  document.addEventListener("astro:page-load", setup);
  document.addEventListener("astro:after-swap", () => ctx?.revert());
</script>

<style>
  .concept-demo {
    margin: 1.75rem 0 2rem;
    padding: 1.4rem 1.6rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg-raised);
  }

  .concept-demo-label {
    margin: 0 0 1.1rem;
    font-size: 0.68rem;
    letter-spacing: 0.06em;
    color: var(--accent-text, var(--accent));
  }

  .citation-chunk,
  .citation-answer {
    padding: 0.9rem 1.1rem;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    background: var(--bg-card);
  }

  .citation-chunk-label,
  .citation-answer-label {
    display: block;
    margin-bottom: 0.5rem;
    font-size: 0.62rem;
    letter-spacing: 0.04em;
    color: var(--text-secondary);
  }

  .citation-chunk-text,
  .citation-answer-text {
    margin: 0;
    font-size: 0.88rem;
    line-height: 1.6;
    color: var(--text-secondary);
  }

  .citation-highlight {
    background: color-mix(in srgb, var(--accent) 30%, transparent);
    color: var(--text);
    font-weight: 600;
    border-radius: 3px;
    box-decoration-break: clone;
    -webkit-box-decoration-break: clone;
    padding: 0.05rem 0.15rem;
  }

  .citation-marker {
    display: inline-flex;
    color: var(--accent-text, var(--accent));
    font-weight: 700;
    font-size: 0.75rem;
  }

  .citation-arrow {
    margin: 1rem 0;
    font-size: 0.72rem;
    color: var(--text-secondary);
  }

  .citation-footnote {
    margin: 0.6rem 0 0;
    font-size: 0.72rem;
    color: var(--text-secondary);
  }

  .citation-footnote a {
    color: var(--accent-text, var(--accent));
  }
</style>
