---
// Bespoke concept demo for Module 38 (Multi-modal ingestion) — the whole
// module's story in one visual: four formats, each extracted its own way,
// converging into one index that a single query can search across. This
// carries the page's main point so the prose around it can stay short.
const FORMATS = [
  { id: "html", label: "HTML", via: "strip boilerplate" },
  { id: "pdf", label: "PDF", via: "layout-aware OCR" },
  { id: "txt", label: "TXT", via: "as-is" },
  { id: "video", label: "VIDEO", via: "transcript + keyframes" },
];

const RESULTS = [
  { modality: "VIDEO", source: "claim_042.mp4 @ 01:32", detail: "keyframe shows missing shingles on the north slope" },
  { modality: "PDF", source: "adjuster_report.pdf, p.3", detail: "\"roof damage consistent with wind, not wear\"" },
  { modality: "HTML", source: "claims-faq page", detail: "\"attach photos or video for faster review\"" },
];
---

<figure class="concept-demo converge-demo" data-converge-demo aria-label="Four document formats, extracted differently, converging into one searchable index">
  <figcaption class="concept-demo-label mono">[ SEE IT: FOUR FORMATS, ONE INDEX ]</figcaption>

  <div class="converge-formats">
    {
      FORMATS.map((f) => (
        <div class="converge-format" data-converge-item>
          <span class="converge-format-label mono">{f.label}</span>
          <span class="converge-format-via">{f.via}</span>
        </div>
      ))
    }
  </div>

  <div class="converge-lines" data-converge-item aria-hidden="true">
    <svg viewBox="0 0 400 60" preserveAspectRatio="none">
      <path d="M50 0 L200 55" stroke="var(--border)" stroke-width="1"></path>
      <path d="M150 0 L200 55" stroke="var(--border)" stroke-width="1"></path>
      <path d="M250 0 L200 55" stroke="var(--border)" stroke-width="1"></path>
      <path d="M350 0 L200 55" stroke="var(--border)" stroke-width="1"></path>
    </svg>
  </div>

  <div class="converge-index" data-converge-item>
    <span class="converge-index-ring"></span>
    <span class="chip chip--accent">UNIFIED VECTOR INDEX</span>
  </div>

  <div class="converge-query mono" data-converge-item>QUERY → "what does the walkthrough show about roof damage?"</div>

  <ol class="converge-results">
    {
      RESULTS.map((r) => (
        <li class="converge-result" data-converge-item>
          <span class="converge-modality mono">{r.modality}</span>
          <span class="converge-result-body">
            <span class="converge-source mono">{r.source}</span>
            <span class="converge-detail">{r.detail}</span>
          </span>
        </li>
      ))
    }
  </ol>
</figure>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  let ctx: gsap.Context | undefined;

  function setup() {
    const rootEl = document.querySelector<HTMLElement>("[data-converge-demo]");
    if (!rootEl) return;
    ctx?.revert();
    ctx = gsap.context(() => {
      const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const items = gsap.utils.toArray<HTMLElement>("[data-converge-item]", rootEl);
      const results = gsap.utils.toArray<HTMLElement>(".converge-result", rootEl);

      if (reduced) {
        gsap.set([items, results], { autoAlpha: 1, y: 0 });
        return;
      }

      gsap.set(items, { autoAlpha: 0, y: 10 });
      gsap.set(results, { autoAlpha: 0, y: 10 });

      const tl = gsap.timeline({ scrollTrigger: { trigger: rootEl, start: "top 85%", once: true } });
      tl.to('[data-converge-item].converge-format, .converge-format', { autoAlpha: 1, y: 0, duration: 0.3, ease: "power2.out", stagger: 0.1 })
        .to(items.filter((el) => el.classList.contains("converge-lines")), { autoAlpha: 1, y: 0, duration: 0.3 }, "+=0.05")
        .to(items.filter((el) => el.classList.contains("converge-index")), { autoAlpha: 1, y: 0, duration: 0.35, ease: "back.out(1.6)" }, "+=0.05")
        .to(items.filter((el) => el.classList.contains("converge-query")), { autoAlpha: 1, y: 0, duration: 0.3 }, "+=0.2")
        .to(results, { autoAlpha: 1, y: 0, duration: 0.3, ease: "power2.out", stagger: 0.12 }, "+=0.1");
    }, rootEl);
  }

  setup();
  document.addEventListener("astro:page-load", setup);
  document.addEventListener("astro:after-swap", () => ctx?.revert());
</script>

<style>
  .concept-demo {
    margin: 1.75rem 0 2rem;
    padding: 1.4rem 1.6rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg-raised);
  }

  .concept-demo-label {
    margin: 0 0 1.1rem;
    font-size: 0.68rem;
    letter-spacing: 0.06em;
    color: var(--accent-text, var(--accent));
  }

  .converge-formats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.75rem;
  }

  .converge-format {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
    padding: 0.6rem 0.4rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg-card);
    text-align: center;
  }

  .converge-format-label {
    font-weight: 700;
    font-size: 0.78rem;
    color: var(--text);
  }

  .converge-format-via {
    font-size: 0.65rem;
    color: var(--text-secondary);
  }

  .converge-lines svg {
    display: block;
    width: 100%;
    height: 44px;
  }

  .converge-index {
    position: relative;
    display: flex;
    justify-content: center;
    margin: 0.25rem 0 1.1rem;
  }

  .converge-index-ring {
    position: absolute;
    width: 44px;
    height: 44px;
    border-radius: 999px;
    border: 1.5px dashed var(--accent);
    opacity: 0.4;
  }

  .converge-query {
    margin: 0 0 0.9rem;
    font-size: 0.85rem;
    color: var(--text);
  }

  .converge-results {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .converge-result {
    display: flex;
    align-items: flex-start;
    gap: 0.7rem;
    padding: 0.55rem 0.75rem;
    border-radius: var(--radius);
    background: var(--bg-card);
    border: 1px solid var(--border);
  }

  .converge-result:first-child {
    border-color: var(--accent);
    box-shadow: 0 0 0 1px var(--accent);
  }

  .converge-modality {
    flex: none;
    font-size: 0.62rem;
    padding: 0.15rem 0.4rem;
    border-radius: 3px;
    background: color-mix(in srgb, var(--accent) 25%, transparent);
    color: var(--accent-text, var(--accent));
  }

  .converge-result-body {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .converge-source {
    font-size: 0.68rem;
    color: var(--text-secondary);
  }

  .converge-detail {
    font-size: 0.85rem;
    color: var(--text);
  }

  @media (max-width: 640px) {
    .converge-formats {
      grid-template-columns: repeat(2, 1fr);
    }

    .converge-lines {
      display: none;
    }
  }
</style>
