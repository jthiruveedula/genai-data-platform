---
import { CLOUDS } from "../data/modules";
import { loadClaims, findClaim, claimStatus, type ClaimStatus } from "../lib/claims";

interface Props {
  moduleId: string;
  entries: Record<string, { services: string[]; snippet: string; labSteps: string[]; costNote: string; claimId: string }>;
}

const { moduleId, entries } = Astro.props;
const base = import.meta.env.BASE_URL;

const claims = loadClaims();
const now = new Date();

const MONTH_YEAR = new Intl.DateTimeFormat("en-US", { month: "short", year: "numeric" });

function claimChipClass(status: ClaimStatus): string {
  if (status === "verified") return "chip chip--claim-verified";
  if (status === "stale") return "chip chip--pending chip--claim-stale";
  return "chip chip--pending chip--claim-unverified";
}

function claimLabel(status: ClaimStatus, verifiedOn: string | null): string {
  if (status === "verified" && verifiedOn) {
    return `✓ VERIFIED ${MONTH_YEAR.format(new Date(verifiedOn)).toUpperCase()}`;
  }
  if (status === "stale" && verifiedOn) {
    return `⚠ STALE · LAST ${MONTH_YEAR.format(new Date(verifiedOn)).toUpperCase()}`;
  }
  return "UNVERIFIED";
}
---

<div class="flavor-tabs" data-flavor-tabs role="tablist" aria-label="Cloud flavor">
  {
    CLOUDS.map((c, i) => (
      <button
        type="button"
        role="tab"
        id={`tab-${moduleId}-${c.id}`}
        aria-controls={`panel-${moduleId}-${c.id}`}
        aria-selected="false"
        data-tab-cloud={c.id}
        tabindex={i === 0 ? 0 : -1}
      >
        {c.label}
      </button>
    ))
  }
</div>

{
  CLOUDS.map((c) => {
    const entry = entries[c.id];
    const claim = findClaim(claims, entry.claimId);
    const status: ClaimStatus = claim ? claimStatus(claim, now) : "unverified";
    const claimHref = `${base}freshness/#claim-${entry.claimId}`;
    const claimTitle =
      status === "verified"
        ? "Checked by the validation pipeline — see the content freshness page"
        : status === "stale"
          ? "Last checked over 90 days ago and due for re-verification — see the content freshness page"
          : "No validation pipeline has checked this claim yet — see the content freshness page";
    return (
      <div role="tabpanel" id={`panel-${moduleId}-${c.id}`} aria-labelledby={`tab-${moduleId}-${c.id}`} data-panel-cloud={c.id} hidden>
        <p class="services">
          <span class="chip">{entry.services.join(" · ")}</span>{" "}
          <a class={claimChipClass(status)} data-claim-id={entry.claimId} href={claimHref} title={claimTitle}>
            {claimLabel(status, claim?.verifiedOn ?? null)}
          </a>
        </p>
        <pre class="mono snippet"><code>{entry.snippet}</code></pre>
        <ol class="lab-steps">
          {entry.labSteps.map((s) => <li>{s}</li>)}
        </ol>
        <p class="cost-note chip">{entry.costNote}</p>
      </div>
    );
  })
}

<script>
  function activate(container: Element, cloud: string) {
    container.querySelectorAll<HTMLButtonElement>("[data-tab-cloud]").forEach((tab) => {
      const active = tab.dataset.tabCloud === cloud;
      tab.setAttribute("aria-selected", String(active));
      tab.tabIndex = active ? 0 : -1;
    });
    const root = container.parentElement;
    root?.querySelectorAll<HTMLElement>("[data-panel-cloud]").forEach((panel) => {
      panel.hidden = panel.dataset.panelCloud !== cloud;
    });
  }

  document.querySelectorAll<HTMLElement>("[data-flavor-tabs]").forEach((container) => {
    const initial = document.documentElement.getAttribute("data-cloud") || "gcp";
    activate(container, initial);

    container.querySelectorAll<HTMLButtonElement>("[data-tab-cloud]").forEach((tab, i, all) => {
      tab.addEventListener("click", () => activate(container, tab.dataset.tabCloud!));
      tab.addEventListener("keydown", (e) => {
        if (e.key !== "ArrowRight" && e.key !== "ArrowLeft") return;
        const dir = e.key === "ArrowRight" ? 1 : -1;
        const next = all[(i + dir + all.length) % all.length];
        next.focus();
        activate(container, next.dataset.tabCloud!);
      });
    });
  });

  document.addEventListener("click", (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>("[data-cloud-btn]");
    if (!btn) return;
    document.querySelectorAll<HTMLElement>("[data-flavor-tabs]").forEach((c) => activate(c, btn.dataset.cloudBtn!));
  });
</script>

<style>
  .flavor-tabs {
    display: flex;
    gap: 0.35rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 1.25rem;
  }

  .flavor-tabs button {
    background: transparent;
    border: none;
    border-bottom: 2px solid transparent;
    padding: 0.6rem 1rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    letter-spacing: 0.02em;
    color: var(--text-secondary);
    cursor: pointer;
    min-height: 44px;
    transition:
      color var(--duration-micro) var(--ease-out),
      border-color var(--duration-micro) var(--ease-out);
  }

  .flavor-tabs button:hover {
    color: var(--text);
  }

  .flavor-tabs button[aria-selected="true"] {
    color: var(--accent-text, var(--accent));
    border-bottom-color: var(--accent);
  }

  [data-panel-cloud] {
    padding: 1.5rem;
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: calc(var(--radius) + 4px);
    backdrop-filter: blur(var(--glass-blur));
    -webkit-backdrop-filter: blur(var(--glass-blur));
  }

  /* The claim chip is an <a> (linking to the freshness page) rather than a
     plain <span> — undo the browser's default link underline so it keeps
     the same pill look every other .chip has, and give it a visible hover
     state since chips otherwise have none. */
  a[data-claim-id] {
    text-decoration: none;
  }

  a[data-claim-id]:hover {
    color: var(--text);
  }

  /* Distinct, theme-aware colors per claim status (mirrors freshness.astro):
     mixing a hue into --text keeps each status legible against
     --bg-card/--glass-bg in both dark and light themes, rather than a fixed
     hex that only reads well in one. */
  .chip--claim-verified {
    border-color: color-mix(in srgb, #22c55e 55%, var(--border));
    color: color-mix(in srgb, #22c55e 55%, var(--text));
  }

  .chip--claim-verified::before,
  .chip--claim-verified::after {
    color: color-mix(in srgb, #22c55e 55%, var(--text));
  }

  .chip--claim-unverified {
    border-color: color-mix(in srgb, #f59e0b 55%, var(--border));
    color: color-mix(in srgb, #f59e0b 55%, var(--text));
  }

  .chip--claim-unverified::before,
  .chip--claim-unverified::after {
    color: color-mix(in srgb, #f59e0b 55%, var(--text));
  }

  .chip--claim-stale {
    border-color: color-mix(in srgb, #ef4444 55%, var(--border));
    color: color-mix(in srgb, #ef4444 55%, var(--text));
  }

  .chip--claim-stale::before,
  .chip--claim-stale::after {
    color: color-mix(in srgb, #ef4444 55%, var(--text));
  }

  .services {
    display: flex;
    gap: 0.5rem;
    margin: 0 0 1rem;
  }

  .snippet {
    background: var(--code-bg);
    color: #e8e8e8;
    padding: 1rem;
    border-radius: var(--radius);
    border-left: 2px solid var(--code-highlight, var(--accent));
    overflow-x: auto;
    font-size: 0.82rem;
    line-height: 1.55;
  }

  .lab-steps {
    padding-left: 0;
    margin: 1.25rem 0 0;
    list-style: none;
    counter-reset: lab-step;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .lab-steps li {
    position: relative;
    padding-left: 2rem;
    color: var(--text);
    line-height: 1.5;
  }

  .lab-steps li::before {
    counter-increment: lab-step;
    content: counter(lab-step);
    position: absolute;
    left: 0;
    top: 0.05em;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.4rem;
    height: 1.4rem;
    border-radius: 50%;
    border: 1px solid var(--accent);
    color: var(--accent-text, var(--accent));
    font-family: var(--font-mono);
    font-size: 0.7rem;
  }

  .cost-note {
    display: inline-block;
    margin-top: 1.25rem;
  }
</style>
