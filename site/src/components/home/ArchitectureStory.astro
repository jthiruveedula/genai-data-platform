---
// Redesign: a horizontal, scroll-scrubbed "coverflow" of the 10 lifecycle
// stages, driven by vertical scroll (pin the section, translate the card
// track horizontally). Replaces the previous vertical S-curve rail, whose
// label-alignment bug (see git history) was the trigger to rebuild this
// scene with a simpler, more robust coordinate model: cards are plain flow
// layout (no SVG viewBox math to get wrong), and the HUD progress rail is a
// single flat percentage-positioned bar instead of a separately-scaled SVG.
import { LIFECYCLE } from "../../data/platform";

const STAGE_COUNT = LIFECYCLE.length;
---

<section id="architecture" class="arch-story" data-arch-story aria-labelledby="arch-heading">
  <div class="scene-inner arch-intro">
    <p class="section-kicker">THE LIFECYCLE</p>
    <h2 id="arch-heading" class="section-title">One document. Ten stages. Any cloud.</h2>
    <p class="section-lede">
      Scroll to follow a single messy PDF from ingestion to a grounded, cited answer — and watch every stage re-map
      when you switch clouds.
    </p>
  </div>

  <div class="arch-pin" data-arch-pin>
    <div class="arch-hud">
      <span class="arch-hud-count mono" data-arch-count aria-live="off">01 / {String(STAGE_COUNT).padStart(2, "0")}</span>
      <div class="arch-hud-rail" data-arch-hud-rail>
        <span class="hud-rail-fill" data-arch-fill></span>
        {
          LIFECYCLE.map((_, i) => (
            <span class="hud-tick" data-hud-tick={i} style={`left:${(i / (STAGE_COUNT - 1)) * 100}%`} />
          ))
        }
        <span class="hud-token" data-arch-token aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none">
            <path d="M5 2h10l4 4v16H5Z" fill="var(--bg-card)" stroke="var(--accent)" stroke-width="1.4" stroke-linejoin="round"></path>
            <path d="M15 2v4h4Z" fill="var(--accent)" opacity="0.55"></path>
            <path d="M8 12h8M8 15.5h5" stroke="var(--text-secondary)" stroke-width="1.3" stroke-linecap="round"></path>
          </svg>
        </span>
      </div>
      <span class="chip chip--accent arch-hud-chip" data-arch-hud-chip>{LIFECYCLE[0].label}</span>
    </div>

    <div class="arch-track-viewport">
      <div class="arch-track" data-arch-track>
        {
          LIFECYCLE.map((stage, i) => (
            <article class="arch-card glass-panel" data-arch-card>
              <span class="arch-card-ghost mono" aria-hidden="true">
                {String(i + 1).padStart(2, "0")}
              </span>
              <span class="chip chip--accent">{stage.label}</span>
              <p class="arch-card-narration">{stage.narration}</p>
              <p class="arch-card-service mono">
                <span class="arch-card-service-label">ON YOUR STACK →</span>
                <span class="cloud-swap">
                  <span data-for="neutral">{stage.services.neutral}</span>
                  <span data-for="gcp">{stage.services.gcp}</span>
                  <span data-for="aws">{stage.services.aws}</span>
                  <span data-for="azure">{stage.services.azure}</span>
                  <span data-for="oss">{stage.services.oss}</span>
                </span>
              </p>
            </article>
          ))
        }
      </div>
    </div>
  </div>

  <ol class="arch-list" data-arch-list aria-label="Platform lifecycle stages">
    {
      LIFECYCLE.map((stage, i) => (
        <li class="list-row" data-list-row>
          <span class="row-index mono">{String(i + 1).padStart(2, "0")}</span>
          <div class="row-body">
            <span class="chip chip--accent">{stage.label}</span>
            <p class="row-narration">{stage.narration}</p>
            <p class="row-service mono">
              <span class="readout-service-label">ON YOUR STACK →</span>
              <span class="cloud-swap">
                <span data-for="neutral">{stage.services.neutral}</span>
                <span data-for="gcp">{stage.services.gcp}</span>
                <span data-for="aws">{stage.services.aws}</span>
                <span data-for="azure">{stage.services.azure}</span>
                <span data-for="oss">{stage.services.oss}</span>
              </span>
            </p>
          </div>
        </li>
      ))
    }
  </ol>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { LIFECYCLE } from "../../data/platform";

  gsap.registerPlugin(ScrollTrigger);

  let ctx: gsap.Context | undefined;
  let resizeTimer: ReturnType<typeof setTimeout> | undefined;

  function setup() {
    const rootEl = document.querySelector<HTMLElement>("[data-arch-story]");
    if (!rootEl) return;
    ctx?.revert();

    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const wide = window.innerWidth >= 768;
    const pinned = wide && !reduced;

    ctx = gsap.context(() => {
      const list = rootEl.querySelector<HTMLElement>("[data-arch-list]");
      const pin = rootEl.querySelector<HTMLElement>("[data-arch-pin]");

      if (!pinned) {
        if (pin) pin.style.display = "none";
        if (list) list.style.display = "flex";
        if (!list) return;

        const rows = gsap.utils.toArray<HTMLElement>("[data-list-row]", list);
        if (reduced) {
          gsap.set(rows, { autoAlpha: 1, y: 0 });
          return;
        }
        rows.forEach((row) => {
          gsap.from(row, {
            autoAlpha: 0,
            y: 24,
            duration: 0.5,
            ease: "power2.out",
            scrollTrigger: { trigger: row, start: "top 88%", once: true },
          });
        });
        return;
      }

      if (list) list.style.display = "none";
      if (pin) pin.style.display = "";

      const cards = gsap.utils.toArray<HTMLElement>("[data-arch-card]", rootEl);
      const track = rootEl.querySelector<HTMLElement>("[data-arch-track]");
      const viewport = rootEl.querySelector<HTMLElement>(".arch-track-viewport");
      const hudCount = rootEl.querySelector<HTMLElement>("[data-arch-count]");
      const hudChip = rootEl.querySelector<HTMLElement>("[data-arch-hud-chip]");
      const hudFill = rootEl.querySelector<HTMLElement>("[data-arch-fill]");
      const hudToken = rootEl.querySelector<HTMLElement>("[data-arch-token]");
      const ticks = gsap.utils.toArray<HTMLElement>("[data-hud-tick]", rootEl);
      if (!track || !viewport || !cards.length) return;

      const n = cards.length;
      const labels = LIFECYCLE.map((s) => s.label);
      let lastActive = -1;

      // Measured, not hardcoded: the previous version's bug came from
      // assuming a fixed coordinate mapping between two boxes that could
      // drift out of sync. Reading real rendered dimensions means there is
      // nothing to drift — a resize just re-measures.
      function measure() {
        const cardRect = cards[0].getBoundingClientRect();
        const trackStyle = getComputedStyle(track!);
        const gap = parseFloat(trackStyle.columnGap || trackStyle.gap || "0") || 0;
        const viewportWidth = viewport!.getBoundingClientRect().width;
        return { cardWidth: cardRect.width, gap, viewportWidth };
      }

      let dims = measure();

      function render(progress: number) {
        const t = progress * (n - 1);
        const step = dims.cardWidth + dims.gap;
        const x = (dims.viewportWidth - dims.cardWidth) / 2 - t * step;
        gsap.set(track, { x });

        cards.forEach((card, i) => {
          const d = i - t;
          const ad = Math.min(Math.abs(d), 2);
          gsap.set(card, {
            scale: 1 - ad * 0.12,
            autoAlpha: 1 - ad * 0.32,
            rotationY: gsap.utils.clamp(-34, 34, d * -17),
            zIndex: Math.round(10 - ad),
          });
        });

        const activeIndex = Math.round(gsap.utils.clamp(0, n - 1, t));
        if (hudFill) gsap.set(hudFill, { width: `${progress * 100}%` });
        if (hudToken) gsap.set(hudToken, { left: `${progress * 100}%` });
        ticks.forEach((tick, i) => tick.classList.toggle("is-active", i <= activeIndex));

        if (activeIndex !== lastActive) {
          lastActive = activeIndex;
          if (hudCount) hudCount.textContent = `${String(activeIndex + 1).padStart(2, "0")} / ${String(n).padStart(2, "0")}`;
          if (hudChip) hudChip.textContent = labels[activeIndex];
        }
      }

      if (reduced) {
        // Unreachable in practice (reduced-motion takes the !pinned branch
        // above), kept only as a defensive fallback if this ever runs.
        render(0);
        return;
      }

      gsap.set(cards, { transformOrigin: "50% 50%" });
      render(0);

      ScrollTrigger.create({
        trigger: pin,
        start: "top top",
        end: "+=450%",
        scrub: 1,
        pin: true,
        onRefresh: (self) => {
          dims = measure();
          render(self.progress);
        },
        onUpdate: (self) => render(self.progress),
      });
    }, rootEl);
  }

  function onCloudChange() {
    const rootEl = document.querySelector<HTMLElement>("[data-arch-story]");
    if (!rootEl) return;
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
    const active = rootEl.querySelectorAll<HTMLElement>(".cloud-swap");
    gsap.fromTo(active, { autoAlpha: 0.3 }, { autoAlpha: 1, duration: 0.3, ease: "power2.out", overwrite: "auto" });
  }

  function onResize() {
    if (resizeTimer) clearTimeout(resizeTimer);
    resizeTimer = setTimeout(() => {
      const wide = window.innerWidth >= 768;
      const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const shouldPin = wide && !reduced;
      const currentlyPinned = document.querySelector<HTMLElement>("[data-arch-pin]")?.style.display !== "none";
      if (shouldPin !== currentlyPinned) setup();
    }, 200);
  }

  setup();
  document.addEventListener("astro:page-load", setup);
  document.addEventListener("astro:after-swap", () => ctx?.revert());
  document.addEventListener("gdp:cloud-change", onCloudChange);
  window.addEventListener("resize", onResize);
</script>

<style>
  .arch-story {
    background: var(--bg-deep);
    border-block: 1px solid var(--border);
    padding-block: clamp(3.5rem, 7vw, 5rem) 0;
    background-image: radial-gradient(color-mix(in srgb, var(--text) 6%, transparent) 1px, transparent 1px);
    background-size: 28px 28px;
    background-position: -8px -8px;
  }

  .arch-intro {
    max-width: 46rem;
    padding-bottom: 3rem;
  }

  .arch-pin {
    position: relative;
    height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: clamp(1.5rem, 4vw, 3rem);
    overflow: hidden;
  }

  /* ---- HUD: stage counter, segmented progress rail, active-stage chip ---- */
  .arch-hud {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    max-width: 60rem;
    margin: 0 auto;
    width: 100%;
    padding: 0 1.5rem;
  }

  .arch-hud-count {
    flex: none;
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    color: var(--text-secondary);
    font-variant-numeric: tabular-nums;
  }

  .arch-hud-rail {
    position: relative;
    flex: 1;
    height: 2px;
    background: var(--border);
    border-radius: 2px;
  }

  .hud-rail-fill {
    display: block;
    height: 100%;
    width: 0%;
    background: var(--accent);
    box-shadow: 0 0 8px color-mix(in srgb, var(--accent) 60%, transparent);
    border-radius: 2px;
  }

  .hud-tick {
    position: absolute;
    top: 50%;
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: var(--bg-card);
    border: 1.5px solid var(--border);
    transform: translate(-50%, -50%);
    transition: border-color var(--duration-theme) var(--ease-out), background-color var(--duration-theme) var(--ease-out);
  }

  .hud-tick.is-active {
    border-color: var(--accent);
    background: var(--accent);
  }

  .hud-token {
    position: absolute;
    top: 50%;
    left: 0%;
    width: 22px;
    height: 22px;
    transform: translate(-50%, -50%);
    pointer-events: none;
  }

  .hud-token svg {
    width: 100%;
    height: 100%;
  }

  .arch-hud-chip {
    flex: none;
    min-width: 8rem;
    text-align: center;
    justify-content: center;
  }

  /* ---- Horizontal card track ---- */
  .arch-track-viewport {
    position: relative;
    overflow: hidden;
    perspective: 1600px;
    padding: 1rem 0 2rem;
  }

  .arch-track {
    display: flex;
    gap: 2rem;
    width: max-content;
    will-change: transform;
  }

  .arch-card {
    position: relative;
    flex: 0 0 min(30rem, 82vw);
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    padding: 2rem 2.25rem;
    transform-style: preserve-3d;
    backface-visibility: hidden;
  }

  .arch-card-ghost {
    position: absolute;
    top: 0.5rem;
    right: 1.25rem;
    font-size: 4rem;
    font-weight: 700;
    line-height: 1;
    color: var(--text);
    opacity: 0.06;
    pointer-events: none;
  }

  .arch-card-narration {
    margin: 0;
    font-size: 1.15rem;
    line-height: 1.55;
    color: var(--text);
    max-width: 26rem;
  }

  .arch-card-service {
    margin: 0.25rem 0 0;
    font-size: 0.85rem;
    color: var(--accent-text, var(--accent));
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .arch-card-service-label {
    color: var(--text-secondary);
    letter-spacing: 0.08em;
    font-size: 0.65rem;
  }

  /* ---- Mobile / reduced-motion fallback list ---- */
  .arch-list {
    display: none;
    flex-direction: column;
    gap: 0;
    list-style: none;
    margin: 0;
    padding: 0 1.5rem 3rem;
    max-width: 46rem;
    margin-inline: auto;
  }

  .list-row {
    position: relative;
    display: flex;
    gap: 1.25rem;
    padding: 1.25rem 0;
    border-left: 2px solid var(--border);
    padding-left: 1.5rem;
  }

  .list-row::before {
    content: "";
    position: absolute;
    left: -6px;
    top: 1.6rem;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--bg-card);
    border: 1.5px solid var(--accent);
  }

  .row-index {
    flex: none;
    font-size: 0.8rem;
    color: var(--text-secondary);
  }

  .row-body {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .row-narration {
    margin: 0;
    line-height: 1.55;
    color: var(--text);
  }

  .row-service {
    margin: 0;
    font-size: 0.8rem;
    color: var(--accent-text, var(--accent));
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .readout-service-label {
    color: var(--text-secondary);
    letter-spacing: 0.08em;
    font-size: 0.65rem;
  }

  @media (max-width: 767px) {
    .arch-list {
      display: flex;
    }

    /* CSS-only backstop: setup() also sets this via JS once it runs, but a
       visitor with JS disabled (or a script error before setup() executes)
       would otherwise see both the pinned rail and the fallback list at
       once on mobile. Desktop needs no equivalent rule — .arch-list is
       already display:none by default outside this media query. */
    .arch-pin {
      display: none;
    }
  }
</style>
