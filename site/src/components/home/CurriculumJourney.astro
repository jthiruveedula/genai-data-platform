---
import { MODULES } from "../../data/modules";

const base = import.meta.env.BASE_URL;

const LANE_LABEL: Record<string, string> = {
  beginner: "CORE",
  intermediate: "DEEPEN",
  advanced: "SCALE",
};

const STATUS_TAGS: Record<string, string> = {
  "00-foundations": "CONCEPTS · NO CLOUD SPEND",
  "10-ingestion": "LAB · ~$0.05",
  "15-chunking": "LAB · ~$0.02",
  "20-embeddings": "LAB · ~$0.02",
  "25-serving": "SHIP AN API · ~$0.01/QUERY",
  "35-retrieval": "HYBRID SEARCH LAB · ~$0.03",
};

const ordered = [...MODULES].sort((a, b) => a.order - b.order);

const laneCounts = ordered.reduce(
  (acc, m) => {
    acc[m.path] = (acc[m.path] ?? 0) + 1;
    return acc;
  },
  {} as Record<string, number>,
);

const FUTURE = [
  { title: "Evaluation & LLM-judge calibration", lane: "intermediate" },
  { title: "Multi-tenant & eval-gated deploys", lane: "advanced" },
];
---

<section id="curriculum" class="journey" data-curriculum aria-labelledby="journey-heading">
  <div class="scene-inner">
    <header class="journey-head">
      <p class="section-kicker">THE JOURNEY</p>
      <h2 id="journey-heading" class="section-title">From first token to platform-grade.</h2>
      <p class="section-lede">
        Six missions and counting — each one ends with something running: an API, an index, a dashboard. Beginner to
        advanced, in order.
      </p>
    </header>

    <div class="lane-legend-row">
      <div class="lane-legend" aria-hidden="true">
        <span class="chip chip--accent">CORE · {laneCounts.beginner ?? 0}</span>
        <span class="chip">DEEPEN · {laneCounts.intermediate ?? 0}</span>
        <span class="chip chip--pending">SCALE · SOON</span>
      </div>
      <p class="chip mono progress-summary" data-progress-summary hidden></p>
    </div>

    <div class="spine-wrap">
      <div class="spine" aria-hidden="true"><span class="spine-fill" data-spine-fill></span></div>

      <ol class="missions" aria-label="Curriculum modules">
        {
          ordered.map((m, i) => (
            <li class="mission" data-mission data-module-id={m.id}>
              <span class="mission-node" data-mission-node aria-hidden="true" />
              <article class="mission-card glass-panel">
                <div class="mission-meta">
                  <span class="mission-number mono">{String(i + 1).padStart(2, "0")}</span>
                  <span class="chip chip--accent">{LANE_LABEL[m.path]}</span>
                  <span class="chip quiz-complete-badge" data-quiz-complete-badge hidden>✓ COMPLETE</span>
                </div>
                <div class="mission-body">
                  <h3 class="mission-title">
                    <a href={`${base}modules/${m.id}/`}>{m.title}</a>
                  </h3>
                  <p class="mission-summary">{m.summary}</p>
                  <div class="mission-status">
                    <span class="chip chip--accent">STATUS: LIVE</span>
                    <span class="chip mono">{STATUS_TAGS[m.id] ?? "LAB"}</span>
                  </div>
                </div>
              </article>
            </li>
          ))
        }

        {
          FUTURE.map((f) => (
            <li class="mission mission--locked" data-mission>
              <span class="mission-node mission-node--locked" aria-hidden="true" />
              <article class="mission-card glass-panel mission-card--locked">
                <div class="mission-meta">
                  <span class="mission-number mono">--</span>
                  <span class="chip">{LANE_LABEL[f.lane]}</span>
                </div>
                <div class="mission-body">
                  <h3 class="mission-title mission-title--locked">{f.title}</h3>
                  <div class="mission-status">
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                      <rect x="3" y="6.5" width="8" height="6" rx="1" stroke="currentColor" stroke-width="1.3" />
                      <path d="M4.5 6.5V4.75a2.5 2.5 0 0 1 5 0V6.5" stroke="currentColor" stroke-width="1.3" />
                    </svg>
                    <span class="chip chip--pending">STATUS: IN DEVELOPMENT</span>
                  </div>
                </div>
              </article>
            </li>
          ))
        }
      </ol>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { isModuleComplete, getCompletionSummary } from "../../lib/progress";

  gsap.registerPlugin(ScrollTrigger);

  // Reads gdp.quiz.<id> localStorage entries written by ModuleQuiz.astro on
  // a module page — separate from the GSAP entrance animation below since
  // it's plain DOM/text state, not a tween, and needs to reflect whatever
  // progress exists on THIS load (a full navigation back from a module page
  // re-fires astro:page-load, which is the refresh point this relies on).
  function renderProgress() {
    const rootEl = document.querySelector<HTMLElement>("[data-curriculum]");
    if (!rootEl) return;

    const missions = Array.from(rootEl.querySelectorAll<HTMLElement>("[data-module-id]"));
    const moduleIds = missions.map((el) => el.dataset.moduleId!);

    missions.forEach((el) => {
      const moduleId = el.dataset.moduleId!;
      const badge = el.querySelector<HTMLElement>("[data-quiz-complete-badge]");
      if (badge) badge.hidden = !isModuleComplete(moduleId);
    });

    const summary = rootEl.querySelector<HTMLElement>("[data-progress-summary]");
    if (summary && moduleIds.length) {
      const { completed, total } = getCompletionSummary(moduleIds);
      summary.textContent = `${completed}/${total} MODULES COMPLETE`;
      summary.hidden = completed === 0;
    }
  }

  let ctx: gsap.Context | undefined;

  function setup() {
    const rootEl = document.querySelector<HTMLElement>("[data-curriculum]");
    if (!rootEl) return;
    ctx?.revert();
    ctx = gsap.context(() => {
      const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const cards = gsap.utils.toArray<HTMLElement>("[data-mission]", rootEl);
      const spineFill = rootEl.querySelector<HTMLElement>("[data-spine-fill]");
      const spineWrap = rootEl.querySelector<HTMLElement>(".spine-wrap");

      if (reduced) {
        gsap.set(cards, { autoAlpha: 1, y: 0 });
        gsap.set(spineFill, { scaleY: 1 });
        cards.forEach((c) => c.querySelector("[data-mission-node]")?.classList.add("is-active"));
        return;
      }

      cards.forEach((card) => {
        gsap.from(card, {
          autoAlpha: 0,
          y: 32,
          duration: 0.55,
          ease: "power2.out",
          scrollTrigger: {
            trigger: card,
            start: "top 85%",
            once: true,
            onEnter: () => card.querySelector("[data-mission-node]")?.classList.add("is-active"),
          },
        });
      });

      if (spineFill && spineWrap) {
        gsap.set(spineFill, { scaleY: 0, transformOrigin: "top" });
        gsap.to(spineFill, {
          scaleY: 1,
          ease: "none",
          scrollTrigger: { trigger: spineWrap, start: "top 70%", end: "bottom 70%", scrub: 1 },
        });
      }
    }, rootEl);
  }

  setup();
  renderProgress();
  document.addEventListener("astro:page-load", () => {
    setup();
    renderProgress();
  });
  document.addEventListener("astro:after-swap", () => ctx?.revert());
</script>

<style>
  .journey {
    padding-block: clamp(3.5rem, 7vw, 5.5rem);
  }

  .journey-head {
    max-width: 46rem;
    margin-bottom: 1.5rem;
  }

  .lane-legend-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 2.5rem;
  }

  .lane-legend {
    display: flex;
    gap: 0.6rem;
  }

  .progress-summary {
    color: var(--accent-text, var(--accent));
  }

  .quiz-complete-badge {
    font-size: 0.65rem;
    color: var(--accent-text, var(--accent));
    border-color: var(--accent);
  }

  .spine-wrap {
    position: relative;
    padding-left: 2.25rem;
  }

  .spine {
    position: absolute;
    left: 7px;
    top: 0.75rem;
    bottom: 0.75rem;
    width: 2px;
    background: var(--border);
  }

  .spine-fill {
    display: block;
    width: 100%;
    height: 100%;
    background: var(--accent);
    box-shadow: 0 0 10px color-mix(in srgb, var(--accent) 55%, transparent);
  }

  .missions {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .mission {
    position: relative;
  }

  .mission-node {
    position: absolute;
    left: -2.25rem;
    top: 1.6rem;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--bg-card);
    border: 2px solid var(--border);
    transition: border-color var(--duration-theme) var(--ease-out), box-shadow var(--duration-theme) var(--ease-out);
  }

  .mission-node.is-active {
    border-color: var(--accent);
    box-shadow: 0 0 10px color-mix(in srgb, var(--accent) 60%, transparent);
  }

  .mission-card {
    display: flex;
    gap: 1.5rem;
    padding: 1.5rem 1.75rem;
    transition:
      transform var(--duration-micro) var(--ease-out),
      border-color var(--duration-micro) var(--ease-out),
      box-shadow var(--duration-micro) var(--ease-out);
  }

  .mission-card:hover {
    transform: translateY(-3px);
    border-color: color-mix(in srgb, var(--accent) 45%, var(--glass-border));
  }

  .mission-meta {
    flex: none;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.6rem;
    min-width: 5rem;
  }

  .mission-number {
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--text-secondary);
  }

  .mission-body {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    min-width: 0;
  }

  .mission-title {
    margin: 0;
    font-size: 1.2rem;
  }

  .mission-title a {
    color: var(--text);
    text-decoration: none;
    text-underline-offset: 3px;
  }

  .mission-title a:hover {
    color: var(--accent-text);
    text-decoration: underline;
  }

  .mission-summary {
    margin: 0;
    max-width: 46rem;
    color: var(--text-secondary);
    line-height: 1.55;
  }

  .mission-status {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-top: 0.25rem;
  }

  .mission-status svg {
    color: var(--text-secondary);
  }

  .mission--locked .mission-card--locked {
    opacity: 0.55;
    border-style: dashed;
  }

  .mission-title--locked {
    color: var(--text-secondary);
  }

  @media (max-width: 720px) {
    .mission-card {
      flex-direction: column;
      gap: 0.85rem;
    }

    .mission-meta {
      flex-direction: row;
      align-items: center;
    }
  }
</style>
