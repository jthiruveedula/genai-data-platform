---
import { LIFECYCLE, CONCEPTS } from "../../data/platform";
import { CLOUDS, MODULES } from "../../data/modules";

const base = import.meta.env.BASE_URL;

const stageById = new Map(LIFECYCLE.map((s) => [s.id, s]));

/**
 * HTML service labels absolutely positioned over the SVG schematic.
 * Percentages are relative to the 640x560 viewBox so they track the
 * responsive stage (the wrapper keeps a fixed 640/560 aspect ratio).
 */
const SERVICE_OVERLAYS = [
  { id: "ingest", left: "37.5%", top: "20.4%" },
  { id: "chunk", left: "61.7%", top: "20.4%" },
  { id: "embed", left: "85.5%", top: "20.4%" },
  { id: "index", left: "50%", top: "60.5%" },
  { id: "retrieve", left: "20.3%", top: "85.4%" },
  { id: "llm", left: "50%", top: "85.4%" },
].map((pos) => {
  const stage = stageById.get(pos.id);
  if (!stage) throw new Error(`HeroScene: unknown lifecycle stage "${pos.id}"`);
  return { ...pos, stage };
});
---

<section class="hero" data-hero-scene aria-labelledby="hero-heading">
  <div class="hero-content">
    <div class="kicker-row" data-rise>
      <span class="chip chip--accent">MULTI-CLOUD CURRICULUM</span>
      <span class="chip mono" data-hero-ticker aria-live="off">0 TOKENS · $0.0000</span>
    </div>

    <h1 id="hero-heading" class="hero-title">
      <span class="h1-mask"><span class="h1-line">Build the <span class="hl">data platform</span></span></span>
      <span class="h1-mask"><span class="h1-line">behind serious GenAI.</span></span>
    </h1>

    {
      /* No data-rise here: this paragraph is the page's LCP candidate (largest
         rendered text block above the fold). Gating it behind the entrance
         timeline's fade-in pushed LCP past 2.5s in Lighthouse — a real cost
         for a purely decorative flourish, not one of the pipeline-demonstrating
         scenes this project's own motion budget reserves large animation for. */
    }
    <p class="lede">
      An interactive curriculum that takes one document from raw PDF to grounded, cited answer — on GCP, AWS, Azure,
      or pure open source. Pick your cloud; the whole platform re-maps live.
    </p>

    <div class="cta-row" data-rise>
      <a class="btn btn-primary" href={`${base}modules/00-foundations/`} data-primary-cta data-base={base}>
        <span data-primary-cta-label>Start with Foundations</span>
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      </a>
      <a class="btn btn-ghost" href={`${base}#architecture`}>See the architecture</a>
    </div>

    <div class="switch-block" data-rise>
      <div class="switcher glass-panel" role="group" aria-label="Choose your cloud platform">
        {
          CLOUDS.map((c) => (
            <button type="button" class="switch-btn" data-cloud-btn={c.id} aria-pressed="false">
              <img src={`${base}logos/${c.id}.svg`} width="22" height="22" alt="" />
              <span class="switch-label">{c.label}</span>
              <span class="switch-tagline">{c.tagline}</span>
            </button>
          ))
        }
      </div>
      <p class="switch-caption">The entire site — services, code, costs — re-maps to your stack.</p>
    </div>

    <div class="concepts" data-rise>
      <span class="concepts-label">YOU WILL MASTER</span>
      <ul class="concepts-list" aria-label="Core concepts covered">
        {
          CONCEPTS.map((concept) => (
            <li>
              <span class="chip">{concept}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </div>

  <div class="hero-canvas" aria-hidden="true">
    <div class="hero-glow" data-hero-glow></div>
    <div class="canvas-stage" data-canvas-stage>
      <svg viewBox="0 0 640 560" fill="none" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern id="hs-grid" width="40" height="40" patternUnits="userSpaceOnUse">
            <path d="M40 0H0V40" fill="none" stroke="var(--border)" stroke-opacity="0.35" stroke-width="1"></path>
          </pattern>
          <radialGradient id="hs-glow-grad">
            <stop offset="0" stop-color="var(--accent)" stop-opacity="0.12"></stop>
            <stop offset="1" stop-color="var(--accent)" stop-opacity="0"></stop>
          </radialGradient>
          <linearGradient id="hs-scan-grad" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0" stop-color="var(--accent)" stop-opacity="0"></stop>
            <stop offset="0.5" stop-color="var(--accent)" stop-opacity="0.1"></stop>
            <stop offset="1" stop-color="var(--accent)" stop-opacity="0"></stop>
          </linearGradient>
        </defs>

        <!-- Background: grid + soft accent glow -->
        <rect x="0" y="0" width="640" height="560" fill="url(#hs-grid)" opacity="0.5"></rect>
        <ellipse cx="320" cy="280" rx="260" ry="200" fill="url(#hs-glow-grad)"></ellipse>

        <!-- Flow overlays (dashed accent, packets ride these; drawn under nodes) -->
        <path id="hs-flow-a" class="hs-flow" d="M28 90 H552 C552 180 500 240 414 262" stroke="var(--accent)" stroke-opacity="0.35" stroke-width="1" stroke-dasharray="6 10"></path>
        <path id="hs-flow-b" class="hs-flow" d="M230 300 C160 320 130 370 130 426" stroke="var(--accent)" stroke-opacity="0.35" stroke-width="1" stroke-dasharray="6 10"></path>
        <path id="hs-flow-c" class="hs-flow" d="M68 450 H572" stroke="var(--accent)" stroke-opacity="0.35" stroke-width="1" stroke-dasharray="6 10"></path>

        <!-- Base connectors (drawn on entrance) -->
        <path class="hs-draw" d="M150 90 H175" stroke="var(--border)" stroke-width="1"></path>
        <path class="hs-draw" d="M305 90 H330" stroke="var(--border)" stroke-width="1"></path>
        <path class="hs-draw" d="M460 90 H485" stroke="var(--border)" stroke-width="1"></path>
        <path class="hs-draw" d="M552 110 C552 180 500 240 414 262" stroke="var(--border)" stroke-width="1"></path>
        <path class="hs-draw" d="M230 300 C160 320 130 370 130 426" stroke="var(--border)" stroke-width="1"></path>
        <path class="hs-draw" d="M200 450 H260" stroke="var(--border)" stroke-width="1"></path>
        <path class="hs-draw" d="M380 450 H440" stroke="var(--border)" stroke-width="1"></path>

        <!-- Pipeline nodes: top row -->
        <g class="hs-node" data-node="sources">
          <rect x="20" y="70" width="130" height="40" rx="6" fill="var(--bg-card)" stroke="var(--border)"></rect>
          <text class="hs-label" x="85" y="94" text-anchor="middle">SOURCES</text>
        </g>
        <g class="hs-node" data-node="ingest">
          <rect x="175" y="70" width="130" height="40" rx="6" fill="var(--bg-card)" stroke="var(--border)"></rect>
          <text class="hs-label" x="240" y="94" text-anchor="middle">INGEST</text>
        </g>
        <g class="hs-node" data-node="chunk">
          <rect x="330" y="70" width="130" height="40" rx="6" fill="var(--bg-card)" stroke="var(--border)"></rect>
          <text class="hs-label" x="395" y="94" text-anchor="middle">CHUNK</text>
        </g>
        <g class="hs-node" data-node="embed">
          <rect x="485" y="70" width="135" height="40" rx="6" fill="var(--bg-card)" stroke="var(--border)"></rect>
          <text class="hs-label" x="552" y="94" text-anchor="middle">EMBED</text>
        </g>

        <!-- Center: vector DB with concentric ring detail -->
        <g class="hs-node" data-node="index">
          <rect x="230" y="225" width="180" height="105" rx="8" fill="var(--bg-card)" stroke="var(--border)"></rect>
          <text class="hs-label" x="320" y="248" text-anchor="middle">VECTOR DB</text>
          <circle class="hs-ring" cx="320" cy="290" r="14" stroke="var(--accent)" stroke-opacity="0.5"></circle>
          <circle class="hs-ring" cx="320" cy="290" r="24" stroke="var(--accent)" stroke-opacity="0.3" stroke-dasharray="3 5"></circle>
          <circle class="hs-ring" cx="320" cy="290" r="33" stroke="var(--border)" stroke-dasharray="2 6"></circle>
          <circle class="hs-core" cx="320" cy="290" r="3.5" fill="var(--accent)"></circle>
        </g>

        <!-- Bottom row -->
        <g class="hs-node" data-node="retrieve">
          <rect x="60" y="430" width="140" height="40" rx="6" fill="var(--bg-card)" stroke="var(--border)"></rect>
          <text class="hs-label" x="130" y="454" text-anchor="middle">RETRIEVE</text>
        </g>
        <g class="hs-node" data-node="llm">
          <rect x="260" y="430" width="120" height="40" rx="6" fill="var(--bg-card)" stroke="var(--border)"></rect>
          <text class="hs-label" x="320" y="454" text-anchor="middle">LLM</text>
        </g>
        <g class="hs-node" data-node="answer">
          <rect x="440" y="430" width="140" height="40" rx="6" fill="var(--bg-card)" stroke="var(--border)"></rect>
          <text class="hs-label" x="510" y="454" text-anchor="middle">ANSWER</text>
        </g>

        <!-- Packets (revealed + driven by GSAP MotionPath) -->
        <circle class="hs-packet" r="3" fill="var(--accent)" opacity="0"></circle>
        <circle class="hs-packet" r="3" fill="var(--accent)" opacity="0"></circle>
        <circle class="hs-packet" r="3" fill="var(--accent)" opacity="0"></circle>

        <!-- Scanline (parked above the viewBox; GSAP sweeps it) -->
        <rect class="hs-scan" x="0" y="-44" width="640" height="36" fill="url(#hs-scan-grad)"></rect>

        <!-- HUD dressing -->
        <g stroke="var(--border)" stroke-width="1.5" fill="none">
          <path d="M8 22V8h14"></path>
          <path d="M618 8h14v14"></path>
          <path d="M632 538v14h-14"></path>
          <path d="M22 552H8v-14"></path>
        </g>
        <text class="hs-hud" x="596" y="26" text-anchor="end">PIPELINE // LIVE</text>
        <circle cx="608" cy="22.5" r="3" fill="var(--accent)"></circle>
      </svg>

      {
        SERVICE_OVERLAYS.map((o) => (
          <div class="node-service" style={`left:${o.left};top:${o.top};`}>
            <span class="cloud-swap">
              <span data-for="neutral">{o.stage.services.neutral}</span>
              <span data-for="gcp">{o.stage.services.gcp}</span>
              <span data-for="aws">{o.stage.services.aws}</span>
              <span data-for="azure">{o.stage.services.azure}</span>
              <span data-for="oss">{o.stage.services.oss}</span>
            </span>
          </div>
        ))
      }
    </div>
  </div>

  <div class="scroll-cue" data-scroll-cue aria-hidden="true">
    <span>SCROLL</span>
    <span class="cue-line"></span>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { MotionPathPlugin } from "gsap/MotionPathPlugin";
  import { MODULES } from "../../data/modules";
  import { nextIncompleteModule } from "../../lib/progress";

  gsap.registerPlugin(MotionPathPlugin);

  const TOKENS_TARGET = 2483;
  const COST_PER_TOKEN = 0.0000027;

  function tickerText(tokens: number): string {
    return `${Math.round(tokens).toLocaleString()} TOKENS · $${(tokens * COST_PER_TOKEN).toFixed(4)}`;
  }

  const ORDERED_MODULES = [...MODULES].sort((a, b) => a.order - b.order);

  // Plain DOM/text swap, not a tween — kept out of the GSAP context below so
  // it isn't reverted/reapplied on every ClientRouter navigation, and reads
  // localStorage fresh each time (a full navigation back from a module page
  // is what re-fires astro:page-load, the same refresh point CurriculumJourney
  // relies on for its own progress badges).
  function renderResumeCta() {
    const link = document.querySelector<HTMLAnchorElement>("[data-primary-cta]");
    const label = document.querySelector<HTMLElement>("[data-primary-cta-label]");
    if (!link || !label || !ORDERED_MODULES.length) return;

    // Read from data-base (set once from Astro's import.meta.env.BASE_URL),
    // not by parsing link.href — href gets rewritten by this same function,
    // so a second call would otherwise be parsing its own prior output.
    const base = link.dataset.base ?? "/";
    const next = nextIncompleteModule(ORDERED_MODULES.map((m) => m.id));

    if (next === null) {
      // Every module's recap has been seen — nothing left to "start" or "resume".
      link.href = `${base}#curriculum`;
      label.textContent = "Review the curriculum";
    } else if (next === ORDERED_MODULES[0].id) {
      // No progress yet — the default first-visit state, already in the markup.
      link.href = `${base}modules/${next}/`;
      label.textContent = "Start with Foundations";
    } else {
      const mod = ORDERED_MODULES.find((m) => m.id === next)!;
      link.href = `${base}modules/${next}/`;
      label.textContent = `Resume: ${mod.title}`;
    }
  }

  let ctx: gsap.Context | undefined;

  function setup() {
    const rootEl = document.querySelector<HTMLElement>("[data-hero-scene]");
    if (!rootEl) return;
    ctx?.revert();
    ctx = gsap.context(() => {
      const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const cleanups: Array<() => void> = [];

      const ticker = rootEl.querySelector<HTMLElement>("[data-hero-ticker]");
      const stage = rootEl.querySelector<HTMLElement>("[data-canvas-stage]");
      const glow = rootEl.querySelector<HTMLElement>("[data-hero-glow]");
      const cue = rootEl.querySelector<HTMLElement>("[data-scroll-cue]");
      const dbNode = rootEl.querySelector<SVGGElement>('[data-node="index"]');
      const services = gsap.utils.toArray<HTMLElement>(".node-service", rootEl);
      const wires = gsap.utils.toArray<SVGPathElement>(".hs-draw", rootEl);
      const flows = gsap.utils.toArray<SVGPathElement>(".hs-flow", rootEl);
      const packets = gsap.utils.toArray<SVGCircleElement>(".hs-packet", rootEl);
      const nodes = gsap.utils.toArray<SVGGElement>(".hs-node", rootEl);

      // Scroll cue fades once the visitor scrolls (both motion modes;
      // reduced motion snaps instead of tweening).
      if (cue) {
        let hidden = false;
        const onScroll = () => {
          const shouldHide = window.scrollY > 60;
          if (shouldHide === hidden) return;
          hidden = shouldHide;
          if (reduced) {
            gsap.set(cue, { autoAlpha: shouldHide ? 0 : 1 });
          } else {
            gsap.to(cue, { autoAlpha: shouldHide ? 0 : 1, duration: 0.3, ease: "power2.out", overwrite: "auto" });
          }
        };
        window.addEventListener("scroll", onScroll, { passive: true });
        cleanups.push(() => window.removeEventListener("scroll", onScroll));
      }

      if (reduced) {
        // Complete static final state: everything is already visible in the
        // markup (packets/scanline are parked invisible), so only the ticker
        // needs its settled value. No loops, no entrance.
        if (ticker) ticker.textContent = tickerText(TOKENS_TARGET);
        return () => cleanups.forEach((fn) => fn());
      }

      // ---- 1. Entrance -------------------------------------------------
      gsap.set(flows, { autoAlpha: 0 });
      wires.forEach((p) => {
        const len = p.getTotalLength();
        gsap.set(p, { strokeDasharray: len, strokeDashoffset: len });
      });

      const entrance = gsap.timeline({ defaults: { ease: "power3.out" } });
      entrance
        .from(rootEl.querySelectorAll(".h1-line"), { yPercent: 30, autoAlpha: 0, duration: 0.7, stagger: 0.08 })
        .from(
          rootEl.querySelectorAll("[data-rise]"),
          { y: 14, autoAlpha: 0, duration: 0.55, ease: "power2.out", stagger: 0.06 },
          "-=0.35",
        )
        .from(
          nodes,
          { scale: 0.8, autoAlpha: 0, transformOrigin: "50% 50%", duration: 0.5, ease: "back.out(1.6)", stagger: 0.05 },
          "-=0.4",
        )
        .to(wires, { strokeDashoffset: 0, duration: 0.8, ease: "power2.inOut", stagger: 0.06 }, "-=0.25")
        .to(flows, { autoAlpha: 1, duration: 0.6, ease: "power2.out" }, "-=0.4")
        .to(packets, { autoAlpha: 1, duration: 0.4 }, "<");

      // ---- 2. Ambient loop ---------------------------------------------
      const routes = [
        { selector: "#hs-flow-a", duration: 7, delay: 0.9 },
        { selector: "#hs-flow-b", duration: 4, delay: 2.2 },
        { selector: "#hs-flow-c", duration: 5.5, delay: 1.5 },
      ];
      packets.forEach((packet, i) => {
        const route = routes[i];
        const pathEl = route ? rootEl.querySelector<SVGPathElement>(route.selector) : null;
        if (!route || !pathEl) return;
        gsap.to(packet, {
          motionPath: { path: pathEl, align: pathEl, alignOrigin: [0.5, 0.5] },
          duration: route.duration,
          delay: route.delay,
          repeat: -1,
          ease: "none",
        });
      });

      // Dash period is 16px (6 + 10) — a multiple keeps the loop seamless.
      gsap.to(flows, { strokeDashoffset: "-=96", duration: 6, repeat: -1, ease: "none" });

      const scan = rootEl.querySelector<SVGRectElement>(".hs-scan");
      if (scan) {
        gsap.fromTo(
          scan,
          { y: 0 },
          { y: 640, duration: 3.4, repeat: -1, repeatDelay: 4.6, ease: "power1.inOut", delay: 1.4 },
        );
      }

      // ---- 3. Ticker -----------------------------------------------------
      if (ticker) {
        const counter = { tokens: 0 };
        gsap.timeline({ repeat: -1, repeatDelay: 2.4 }).fromTo(
          counter,
          { tokens: 0 },
          {
            tokens: TOKENS_TARGET,
            duration: 1.4,
            ease: "power1.out",
            onUpdate: () => {
              ticker.textContent = tickerText(counter.tokens);
            },
          },
        );
      }

      // ---- 4. Pointer parallax (desktop only) ---------------------------
      const desktop = window.matchMedia("(min-width: 768px)").matches;
      if (desktop && stage && glow) {
        const stageX = gsap.quickTo(stage, "x", { duration: 0.7, ease: "power3.out" });
        const stageY = gsap.quickTo(stage, "y", { duration: 0.7, ease: "power3.out" });
        const glowX = gsap.quickTo(glow, "x", { duration: 0.9, ease: "power3.out" });
        const glowY = gsap.quickTo(glow, "y", { duration: 0.9, ease: "power3.out" });
        const clamp = gsap.utils.clamp(-0.5, 0.5);
        const onMove = (e: PointerEvent) => {
          const r = rootEl.getBoundingClientRect();
          const nx = clamp((e.clientX - r.left) / r.width - 0.5);
          const ny = clamp((e.clientY - r.top) / r.height - 0.5);
          stageX(nx * 20); // max 10px either way
          stageY(ny * 20);
          glowX(nx * -20); // opposite direction for depth
          glowY(ny * -20);
        };
        rootEl.addEventListener("pointermove", onMove);
        cleanups.push(() => rootEl.removeEventListener("pointermove", onMove));
      }

      // ---- 5. Cloud change pulse ----------------------------------------
      // Accent-stroked SVG recolors itself via CSS var + transition; this
      // only adds the "the schematic reacted" beat.
      const onCloudChange = () => {
        if (dbNode) {
          gsap.fromTo(
            dbNode,
            { scale: 1 },
            { scale: 1.04, transformOrigin: "50% 50%", duration: 0.18, ease: "power2.out", yoyo: true, repeat: 1 },
          );
        }
        if (services.length) {
          gsap.fromTo(services, { autoAlpha: 0.15 }, { autoAlpha: 1, duration: 0.35, ease: "power2.out", overwrite: "auto" });
        }
      };
      document.addEventListener("gdp:cloud-change", onCloudChange);
      cleanups.push(() => document.removeEventListener("gdp:cloud-change", onCloudChange));

      // ---- 6. Scroll cue loop --------------------------------------------
      const cueLine = rootEl.querySelector<HTMLElement>(".cue-line");
      if (cueLine) {
        gsap
          .timeline({ repeat: -1, repeatDelay: 0.35 })
          .fromTo(cueLine, { scaleY: 0, transformOrigin: "50% 0%" }, { scaleY: 1, duration: 0.6, ease: "power2.inOut" })
          .to(cueLine, { scaleY: 0, transformOrigin: "50% 100%", duration: 0.6, ease: "power2.inOut" }, "+=0.15");
      }

      return () => cleanups.forEach((fn) => fn());
    }, rootEl);
  }

  setup();
  renderResumeCta();
  document.addEventListener("astro:page-load", () => {
    setup();
    renderResumeCta();
  });
  document.addEventListener("astro:after-swap", () => ctx?.revert());
</script>

<style>
  .hero {
    position: relative;
    min-height: calc(100dvh - 60px);
    display: grid;
    grid-template-columns: minmax(0, 45fr) minmax(0, 55fr);
    align-items: center;
    gap: clamp(2rem, 5vw, 4rem);
    /* Homepage <main> is full-bleed (see BaseLayout.astro's
       main.main--full-bleed) so every section supplies its own horizontal
       gutter — this one never did, leaving the H1 flush against the
       viewport's left edge at every breakpoint (confirmed: 0px from the
       edge, not a rendering artifact). */
    padding: 2.5rem clamp(1.5rem, 5vw, 3rem) 3.5rem;
  }

  /* ---- Content column (left-aligned) ---- */
  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.4rem;
  }

  .kicker-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.6rem;
  }

  .kicker-row .chip {
    font-size: 0.68rem;
  }

  [data-hero-ticker] {
    font-variant-numeric: tabular-nums;
  }

  .hero-title {
    margin: 0;
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: clamp(2.6rem, 7vw, 5.25rem);
    letter-spacing: -0.035em;
    line-height: 1.02;
    color: var(--text);
  }

  .h1-mask {
    display: block;
    overflow: hidden;
    padding-block: 0.04em;
  }

  .h1-line {
    display: block;
  }

  .hl {
    position: relative;
    white-space: nowrap;
  }

  .hl::after {
    content: "";
    position: absolute;
    left: 0.02em;
    right: 0.02em;
    bottom: 0.03em;
    height: 0.09em;
    border-radius: 2px;
    background: var(--accent);
    opacity: 0.6;
    box-shadow: 0 2px 14px color-mix(in srgb, var(--accent) 45%, transparent);
    transition: background var(--duration-theme) var(--ease-out);
  }

  .lede {
    margin: 0;
    max-width: 34rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  /* ---- CTAs ---- */
  .cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    min-height: 44px;
    padding: 0.8rem 1.4rem;
    border-radius: var(--radius);
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
    transition:
      transform var(--duration-micro) var(--ease-out),
      box-shadow var(--duration-micro) var(--ease-out),
      border-color var(--duration-micro) var(--ease-out),
      background var(--duration-theme) var(--ease-out);
  }

  .btn-primary {
    /* --accent-strong/--accent-contrast (base.css) default to --accent and
       near-black, which clears 4.5:1 for aws/gcp/oss/neutral; azure
       overrides both since its accent needs different handling (see
       azure.css) — using --bg-deep here previously failed WCAG contrast
