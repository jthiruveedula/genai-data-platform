---
import { CLOUDS } from "../../data/modules";

const base = import.meta.env.BASE_URL;

const STATEMENT_LINES = [
  ["Your", "documents", "are", "waiting."],
  ["Pick", "a", "cloud", "and", { text: "start", accent: true }, { text: "building.", accent: true }],
];
---

<section id="start" class="final-cta" data-final-cta aria-labelledby="final-heading">
  <div class="ambient" aria-hidden="true">
    <span class="ambient-glow ambient-glow--a" data-drift-a></span>
    <span class="ambient-glow ambient-glow--b" data-drift-b></span>
  </div>

  <div class="scene-inner cta-content">
    <span class="chip chip--accent">SYSTEM READY</span>

    <h2 id="final-heading" class="cta-statement">
      {
        STATEMENT_LINES.map((line) => (
          <span class="cta-line">
            {line.map((word) => {
              const isObj = typeof word === "object";
              const text = isObj ? word.text : word;
              const accent = isObj && word.accent;
              return (
                <span class="cta-word-mask">
                  <span class={`cta-word ${accent ? "cta-word--accent" : ""}`}>{text}</span>
                </span>
              );
            })}
          </span>
        ))
      }
    </h2>

    <p class="cta-support">Foundations takes a weekend. The platform mindset lasts.</p>

    <div class="cta-actions">
      <a class="btn btn-primary" href={`${base}modules/00-foundations/`}>Enter the curriculum</a>
      <a class="btn btn-ghost" href={`${base}calculator/`}>Estimate your costs</a>
    </div>

    <div class="cta-logos" aria-hidden="true">
      {CLOUDS.map((c) => <img src={`${base}logos/${c.id}.svg`} alt="" width="28" height="28" />)}
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";

  // ScrollTrigger only matters once this below-fold section nears the
  // viewport. Static-importing it (as every homepage scene used to) forced
  // its ~25KB vendor chunk into the same eager parse/eval task as
  // HeroScene's above-fold GSAP work, which is most of the homepage's
  // chronic total-blocking-time overage. Dynamic-importing it here instead
  // means that cost is paid only on scroll, never during Lighthouse's
  // static, no-scroll audit.
  let scrollTriggerReady: Promise<void> | null = null;
  function loadScrollTrigger() {
    if (!scrollTriggerReady) {
      scrollTriggerReady = import("gsap/ScrollTrigger").then(({ ScrollTrigger }) => {
        gsap.registerPlugin(ScrollTrigger);
      });
    }
    return scrollTriggerReady;
  }

  let ctx: gsap.Context | undefined;

  function setup() {
    const rootEl = document.querySelector<HTMLElement>("[data-final-cta]");
    if (!rootEl) return;
    ctx?.revert();
    ctx = gsap.context(() => {
      const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const words = gsap.utils.toArray<HTMLElement>(".cta-word", rootEl);
      const driftA = rootEl.querySelector<HTMLElement>("[data-drift-a]");
      const driftB = rootEl.querySelector<HTMLElement>("[data-drift-b]");

      if (reduced) {
        gsap.set(words, { autoAlpha: 1, y: 0 });
        return;
      }

      gsap.from(words, {
        autoAlpha: 0,
        y: 20,
        duration: 0.5,
        ease: "power2.out",
        stagger: 0.04,
        scrollTrigger: { trigger: rootEl, start: "top 70%", once: true },
      });

      if (driftA) {
        gsap.to(driftA, { x: 40, y: -30, duration: 22, ease: "sine.inOut", yoyo: true, repeat: -1 });
      }
      if (driftB) {
        gsap.to(driftB, { x: -40, y: 30, duration: 26, ease: "sine.inOut", yoyo: true, repeat: -1, delay: 2 });
      }
    }, rootEl);
  }

  // Below-fold, scroll-revealed (once: true) — gating the *first* setup
  // behind an IntersectionObserver (in addition to the dynamic import
  // above) keeps ScrollTrigger.create() off the main thread until the
  // section actually nears the viewport. Later astro:page-load re-setups
  // stay immediate since ScrollTrigger is already loaded by then.
  const finalCtaRootEl = document.querySelector<HTMLElement>("[data-final-cta]");
  if (finalCtaRootEl && typeof IntersectionObserver === "function") {
    const finalCtaObserver = new IntersectionObserver(
      (entries) => {
        if (!entries.some((entry) => entry.isIntersecting)) return;
        finalCtaObserver.disconnect();
        loadScrollTrigger().then(setup);
      },
      { rootMargin: "600px 0px" },
    );
    finalCtaObserver.observe(finalCtaRootEl);
  } else {
    loadScrollTrigger().then(setup);
  }
  document.addEventListener("astro:page-load", () => loadScrollTrigger().then(setup));
  document.addEventListener("astro:after-swap", () => ctx?.revert());
</script>

<style>
  .final-cta {
    position: relative;
    min-height: 70vh;
    display: flex;
    align-items: center;
    background: var(--bg-deep);
    background-image: radial-gradient(color-mix(in srgb, var(--text) 5%, transparent) 1px, transparent 1px);
    background-size: 30px 30px;
    overflow: hidden;
    padding-block: clamp(3rem, 8vw, 5rem);
  }

  .ambient {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .ambient-glow {
    position: absolute;
    width: 42rem;
    height: 42rem;
    border-radius: 50%;
    filter: blur(10px);
  }

  .ambient-glow--a {
    top: -10%;
    left: -10%;
    background: radial-gradient(closest-side, color-mix(in srgb, var(--accent) 10%, transparent), transparent 70%);
  }

  .ambient-glow--b {
    bottom: -15%;
    right: -5%;
    background: radial-gradient(closest-side, color-mix(in srgb, var(--accent-2) 8%, transparent), transparent 70%);
  }

  .cta-content {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.4rem;
    max-width: 46rem;
  }

  .cta-statement {
    margin: 0;
    font-size: clamp(2.2rem, 5.5vw, 3.6rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.1;
  }

  .cta-line {
    display: block;
  }

  .cta-word-mask {
    display: inline-block;
    overflow: hidden;
    vertical-align: top;
    padding-bottom: 0.08em;
  }

  .cta-word {
    display: inline-block;
    margin-right: 0.28em;
  }

  .cta-word--accent {
    color: var(--accent-text, var(--accent));
  }

  .cta-support {
    margin: 0;
    color: var(--text-secondary);
    font-size: 1.05rem;
  }

  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 0.5rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 0.85rem 1.5rem;
    border-radius: var(--radius);
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
    transition:
      transform var(--duration-micro) var(--ease-out),
      box-shadow var(--duration-micro) var(--ease-out),
      border-color var(--duration-micro) var(--ease-out);
  }

  .btn-primary {
    /* See HeroScene.astro's .btn-primary for why: --bg-deep failed WCAG
       contrast against --accent across every cloud in light mode. */
    background: var(--accent-strong, var(--accent));
    color: var(--accent-contrast, var(--bg-deep));
  }

  .btn-primary:hover,
  .btn-primary:focus-visible {
    transform: translateY(-2px);
    box-shadow: 0 10px 30px color-mix(in srgb, var(--accent) 35%, transparent);
  }

  .btn-ghost {
    border: 1px solid var(--border);
    color: var(--text);
  }

  .btn-ghost:hover,
  .btn-ghost:focus-visible {
    transform: translateY(-2px);
    border-color: var(--accent);
  }

  .cta-logos {
    display: flex;
    gap: 1.25rem;
    margin-top: 1.5rem;
  }

  .cta-logos img {
    opacity: 0.5;
    filter: grayscale(1);
    transition: opacity var(--duration-micro) var(--ease-out), filter var(--duration-micro) var(--ease-out);
  }

  .cta-logos img:hover {
    opacity: 1;
    filter: grayscale(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .ambient-glow {
      display: none;
    }
  }
</style>
