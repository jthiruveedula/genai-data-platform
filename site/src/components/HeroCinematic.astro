---
import { CLOUDS } from "../data/modules";
const base = import.meta.env.BASE_URL;
const PIPELINE = ["INGEST", "PARSE", "CHUNK", "EMBED", "RETRIEVE", "ANSWER"];
---

<section class="selector-hero" aria-labelledby="selector-heading">
  <div class="pipeline" aria-hidden="true" data-pipeline>
    <canvas class="burst-canvas" data-burst-canvas></canvas>
    {
      PIPELINE.map((stage, i) => (
        <>
          <span class="chip pipeline-chip" data-stage={stage}>
            {stage}
          </span>
          {i < PIPELINE.length - 1 && <span class="pipeline-arrow">→</span>}
        </>
      ))
    }
  </div>
  <p class="pipeline-caption">Every document on this site travels this exact path — pick a cloud to see it with your services.</p>
  <p class="ticker chip mono" data-ticker aria-live="off">0 TOKENS · $0.0000</p>

  <h1 id="selector-heading" data-scramble="Build a GenAI data platform — on your cloud.">
    Build a GenAI data platform — on your cloud.
  </h1>
  <p class="lede">
    One curriculum. Four flavors. Pick a platform and the whole site — code, diagrams, and cost estimates — adapts.
  </p>
  <div class="cards" role="group" aria-label="Choose your cloud">
    {
      CLOUDS.map((c) => (
        <button type="button" class="cloud-card" data-cloud-btn={c.id} data-select-hero>
          <img src={`${base}logos/${c.id}.svg`} alt="" width="40" height="40" />
          <span class="label">{c.label}</span>
          <span class="tagline">{c.tagline}</span>
          <span class="best-for">{c.bestFor}</span>
        </button>
      ))
    }
  </div>
</section>

<script>
  import { gsap } from "gsap";

  document.querySelectorAll<HTMLButtonElement>("[data-select-hero]").forEach((card) => {
    card.addEventListener("click", () => {
      document.querySelector<HTMLButtonElement>(`[data-cloud-btn="${card.dataset.cloudBtn}"]:not([data-select-hero])`)?.click();
    });
  });

  const SCRAMBLE_CHARS = "!<>-_\\/[]{}—=+*^?#";

  function scrambleIn(el: HTMLElement, finalText: string, duration = 1.1) {
    const state = { progress: 0 };
    gsap.to(state, {
      progress: 1,
      duration,
      ease: "power1.out",
      onUpdate() {
        const revealCount = Math.floor(state.progress * finalText.length);
        let out = "";
        for (let i = 0; i < finalText.length; i++) {
          if (i < revealCount || finalText[i] === " ") out += finalText[i];
          else out += SCRAMBLE_CHARS[(Math.random() * SCRAMBLE_CHARS.length) | 0];
        }
        el.textContent = out;
      },
      onComplete() {
        el.textContent = finalText;
      },
    });
  }

  const TOKENS_TARGET = 2483;
  const COST_PER_TOKEN = 0.0000027;

  function formatTicker(tokens: number) {
    return `${Math.floor(tokens).toLocaleString()} TOKENS · $${(tokens * COST_PER_TOKEN).toFixed(4)}`;
  }

  const HERO_PLAYED_KEY = "gdp.heroPlayed";

  // Opening beat: a lightweight 2D-canvas particle burst that converges onto
  // the pipeline chips' final positions (redesign spec §3.1 HeroCinematic:
  // "Particle burst (WebGL) -> forms pipeline chips"). A real WebGL burst is
  // overkill for a ~700ms accent, so this substitutes a 2D canvas particle
  // sim converging toward each chip's center — same beat, much lower risk.
  // Plays once per tab session (gated on sessionStorage) and only when the
  // user hasn't asked for reduced motion; callers await the returned promise
  // to hand off into the existing pipeline stagger/ticker loop below.
  function runParticleBurst(canvas: HTMLCanvasElement, pipelineEl: HTMLElement, chips: HTMLElement[]): Promise<void> {
    return new Promise((resolve) => {
      const rect = pipelineEl.getBoundingClientRect();
      if (!rect.width || !rect.height || !chips.length) {
        resolve();
        return;
      }

      const dpr = window.devicePixelRatio || 1;
      canvas.width = rect.width * dpr;
      canvas.height = rect.height * dpr;
      canvas.style.width = `${rect.width}px`;
      canvas.style.height = `${rect.height}px`;
      const ctx = canvas.getContext("2d");
      if (!ctx) {
        resolve();
        return;
      }
      ctx.scale(dpr, dpr);

      const targets = chips.map((chip) => {
        const chipRect = chip.getBoundingClientRect();
        return {
          x: chipRect.left - rect.left + chipRect.width / 2,
          y: chipRect.top - rect.top + chipRect.height / 2,
        };
      });

      const centerX = rect.width / 2;
      const centerY = rect.height / 2;
      const PARTICLES_PER_TARGET = 5;
      const particles = targets.flatMap((target) =>
        Array.from({ length: PARTICLES_PER_TARGET }, () => {
          const angle = Math.random() * Math.PI * 2;
          const radius = Math.max(rect.width, rect.height) * (0.4 + Math.random() * 0.3);
          return {
            x: centerX + Math.cos(angle) * radius,
            y: centerY + Math.sin(angle) * radius,
            targetX: target.x,
            targetY: target.y,
            size: 1.5 + Math.random() * 1.5,
          };
        }),
      );

      const DURATION_MS = 550;
      const start = performance.now();
      const accent = getComputedStyle(document.documentElement).getPropertyValue("--accent").trim() || "#7dd3fc";

      function ease(t: number) {
        return 1 - Math.pow(1 - t, 3);
      }

      function frame(now: number) {
        const elapsed = now - start;
        const t = Math.min(elapsed / DURATION_MS, 1);
        const eased = ease(t);

        ctx!.clearRect(0, 0, rect.width, rect.height);
        ctx!.fillStyle = accent;
        ctx!.globalAlpha = 1 - eased * 0.4;
        for (const p of particles) {
          const x = p.x + (p.targetX - p.x) * eased;
          const y = p.y + (p.targetY - p.y) * eased;
          ctx!.beginPath();
          ctx!.arc(x, y, p.size, 0, Math.PI * 2);
          ctx!.fill();
        }

        if (t < 1) {
          requestAnimationFrame(frame);
        } else {
          gsap.to(canvas, {
            autoAlpha: 0,
            duration: 0.15,
            onComplete: () => {
              canvas.remove();
              resolve();
            },
          });
        }
      }

      requestAnimationFrame(frame);
    });
  }

  // NOTE: gsap.matchMedia().add({name: query}, callback) only invokes the
  // callback when the named condition currently evaluates true — for
  // "no-preference" visitors (the vast majority), `{reduceMotion: "(prefers-
  // reduced-motion: reduce)"}` is false and the callback silently never
  // fires (verified against gsap 3.15.0 in Chromium: confirmed via a
  // reduced repro that a `false` named condition never invokes its
  // callback, while a `true` one does). That means the ENTIRE animation
  // setup below — including the reduced-motion branch itself — never ran
  // for typical visitors. Using a plain matchMedia boolean check instead,
  // which is unaffected by that gap.
  function setupHero(reduceMotion: boolean) {
    const heading = document.querySelector<HTMLElement>("[data-scramble]");
    const chips = gsap.utils.toArray<HTMLElement>(".pipeline-chip");
    const cards = gsap.utils.toArray<HTMLElement>(".cloud-card");
    const ticker = document.querySelector<HTMLElement>("[data-ticker]");
    const burstCanvas = document.querySelector<HTMLCanvasElement>("[data-burst-canvas]");
    const pipelineEl = document.querySelector<HTMLElement>("[data-pipeline]");

    if (reduceMotion) {
      burstCanvas?.remove();
      chips.forEach((c) => c.classList.add("chip--accent"));
      if (ticker) ticker.textContent = formatTicker(TOKENS_TARGET);
      return;
    }

    if (heading) {
      const finalText = heading.dataset.scramble || heading.textContent || "";
      scrambleIn(heading, finalText);
    }

    gsap.from(cards, {
      autoAlpha: 0,
      y: 16,
      duration: 0.5,
      ease: "power2.out",
      stagger: 0.06,
      delay: 0.3,
    });

    let cleanupLoop = () => {};

    // Pipeline lights up and the token ticker counts up, then resets and
    // loops — an ambient demonstration of unit economics (PLAN.md §7.0.2),
    // not just decoration: it's teaching "every query costs something."
    function startPipelineLoop() {
      const loop = gsap.timeline({ repeat: -1, repeatDelay: 2, delay: 0.15 });
      loop.set(chips, { autoAlpha: 0, y: 6, scale: 0.92 });
      loop.call(() => chips.forEach((c) => c.classList.remove("chip--accent")));

      chips.forEach((chip, i) => {
        loop.to(
          chip,
          {
            autoAlpha: 1,
            y: 0,
            scale: 1,
            duration: 0.3,
            ease: "back.out(2)",
            onStart: () => chip.classList.add("chip--accent"),
          },
          i * 0.28,
        );
      });

      if (ticker) {
        const counter = { tokens: 0 };
        loop.to(
          counter,
          {
            tokens: TOKENS_TARGET,
            duration: 1.1,
            ease: "power1.out",
            onUpdate: () => {
              ticker.textContent = formatTicker(counter.tokens);
            },
          },
          "-=0.4",
        );
      }

      cleanupLoop = () => {
        loop.kill();
        chips.forEach((c) => c.classList.remove("chip--accent"));
      };
    }

    const alreadyPlayed = sessionStorage.getItem(HERO_PLAYED_KEY);

    if (burstCanvas && pipelineEl && !alreadyPlayed) {
      // Hide the chips up front so the burst appears to *form* them, rather
      // than flashing the final state before the particles arrive.
      gsap.set(chips, { autoAlpha: 0 });
      runParticleBurst(burstCanvas, pipelineEl, chips).then(() => {
        try {
          sessionStorage.setItem(HERO_PLAYED_KEY, "1");
        } catch {
          // sessionStorage unavailable (e.g. private mode) — safe to ignore,
          // the burst simply replays next load.
        }
        startPipelineLoop();
      });
    } else {
      burstCanvas?.remove();
      startPipelineLoop();
    }

    return () => cleanupLoop();
  }

  const motionQuery = window.matchMedia("(prefers-reduced-motion: reduce)");
  let cleanupHero = setupHero(motionQuery.matches);
  motionQuery.addEventListener("change", (e) => {
    cleanupHero?.();
    cleanupHero = setupHero(e.matches);
  });
</script>

<style>
  .selector-hero {
    padding: 3rem 0 2rem;
    text-align: center;
  }

  .pipeline {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-bottom: 0.6rem;
  }

  .burst-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  .pipeline-chip {
    font-size: 0.7rem;
  }

  .pipeline-arrow {
    color: var(--border);
    font-family: var(--font-mono);
  }

  .pipeline-caption {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-secondary);
    margin: 0 0 0.75rem;
  }

  .ticker {
    font-size: 0.7rem;
    font-variant-numeric: tabular-nums;
    margin: 0 auto 1.75rem;
    width: fit-content;
  }

  .selector-hero h1 {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    margin-bottom: 0.5rem;
    min-height: 1.2em;
  }

  .lede {
    color: var(--text-secondary);
    max-width: 38rem;
    margin: 0 auto 2rem;
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1rem;
  }

  .cloud-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.5rem 1rem;
    min-height: 44px;
    cursor: pointer;
    transition: transform var(--duration-micro) var(--ease-out), box-shadow var(--duration-micro) var(--ease-out), border-color var(--duration-micro) var(--ease-out);
  }

  .cloud-card:hover,
  .cloud-card:focus-visible {
    transform: translateY(-3px);
    box-shadow: 0 0 0 1px var(--accent), 0 8px 24px rgba(0, 0, 0, 0.08);
    border-color: var(--accent);
  }

  .cloud-card .label {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.1rem;
  }

  .cloud-card .tagline {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--accent-text, var(--accent));
  }

  .cloud-card .best-for {
    font-size: 0.75rem;
    color: var(--text-secondary);
  }
</style>
