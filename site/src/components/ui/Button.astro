---
// Button.astro — Radix-primitive-inspired button, ported to Astro per the
// redesign spec (section 4.2). Cloud-adaptive via component/semantic CSS
// custom properties (see site/src/styles/tokens/component.css + base.css) —
// no hardcoded colors, so it re-themes per cloud flavor and dark mode with
// zero JS.
//
// Renders <a> when an `href` prop is passed, otherwise <button>. Hover /
// focus-visible states follow the same transition convention already used
// by Navbar.astro's .theme-toggle / .flavor-btn and CloudSelector.astro's
// .cloud-card: `var(--duration-micro) var(--ease-out)`.
import { cva, type VariantProps } from 'class-variance-authority';
import { cn } from '../../lib/utils';

export const buttonVariants = cva('btn', {
  variants: {
    variant: {
      primary: 'btn--primary',
      secondary: 'btn--secondary',
      ghost: 'btn--ghost',
      link: 'btn--link',
      destructive: 'btn--destructive',
    },
    size: {
      sm: 'btn--sm',
      md: 'btn--md',
      lg: 'btn--lg',
    },
  },
  defaultVariants: {
    variant: 'primary',
    size: 'md',
  },
});

type ButtonVariants = VariantProps<typeof buttonVariants>;

interface Props extends ButtonVariants {
  variant?: ButtonVariants['variant'];
  size?: ButtonVariants['size'];
  href?: string;
  class?: string;
  type?: 'button' | 'submit' | 'reset';
}

const { variant = 'primary', size = 'md', href, class: className, type = 'button', ...rest } = Astro.props;

const classes = cn(buttonVariants({ variant, size }), className);
const Tag = href ? 'a' : 'button';
---

<Tag
  class:list={[classes]}
  href={href}
  type={href ? undefined : type}
  {...rest}
>
  <slot />
</Tag>

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    height: var(--btn-height, 36px);
    padding: var(--btn-padding-y, 0.35rem) var(--btn-padding-x, 0.6rem);
    border-radius: var(--btn-radius, var(--radius));
    border: 1px solid transparent;
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: var(--btn-font-weight, 400);
    text-decoration: none;
    cursor: pointer;
    white-space: nowrap;
    transition:
      background-color var(--duration-micro) var(--ease-out),
      border-color var(--duration-micro) var(--ease-out),
      color var(--duration-micro) var(--ease-out),
      box-shadow var(--duration-micro) var(--ease-out),
      transform var(--duration-micro) var(--ease-out);
  }

  .btn:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .btn:active {
    transform: translateY(1px);
  }

  /* Sizes */
  .btn--sm {
    height: calc(var(--btn-height, 36px) - 8px);
    padding: calc(var(--btn-padding-y, 0.35rem) * 0.7) calc(var(--btn-padding-x, 0.6rem) * 0.85);
    font-size: 0.78rem;
  }

  .btn--lg {
    height: calc(var(--btn-height, 36px) + 8px);
    padding: calc(var(--btn-padding-y, 0.35rem) * 1.3) calc(var(--btn-padding-x, 0.6rem) * 1.4);
    font-size: 0.92rem;
  }

  /* Variants */
  .btn--primary {
    background: var(--accent);
    color: var(--accent-text, #fff);
    border-color: var(--accent);
  }

  .btn--primary:hover {
    filter: brightness(1.08);
  }

  .btn--secondary {
    background: var(--bg-card);
    color: var(--text);
    border-color: var(--border);
  }

  .btn--secondary:hover {
    background: var(--bg);
  }

  .btn--ghost {
    background: transparent;
    color: var(--text);
    border-color: transparent;
  }

  .btn--ghost:hover {
    background: var(--bg-card);
  }

  .btn--link {
    background: transparent;
    color: var(--accent-text, var(--accent));
    border-color: transparent;
    height: auto;
    padding: 0;
    text-decoration: underline;
  }

  .btn--link:hover {
    color: var(--accent);
  }

  .btn--destructive {
    background: #b3261e;
    color: #fff;
    border-color: #b3261e;
  }

  .btn--destructive:hover {
    filter: brightness(1.08);
  }

  .btn[disabled] {
    opacity: 0.6;
    cursor: not-allowed;
    pointer-events: none;
  }
</style>
