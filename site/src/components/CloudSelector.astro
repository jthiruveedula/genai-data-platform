---
import { CLOUDS } from "../data/modules";
const base = import.meta.env.BASE_URL;
---

<section class="selector-hero" aria-labelledby="selector-heading">
  <h1 id="selector-heading">Build a GenAI data platform — on your cloud.</h1>
  <p class="lede">
    One curriculum. Four flavors. Pick a platform and the whole site — code, diagrams, and cost estimates — adapts.
  </p>
  <div class="cards" role="group" aria-label="Choose your cloud">
    {
      CLOUDS.map((c) => (
        <button type="button" class="cloud-card" data-cloud-btn={c.id} data-select-hero>
          <img src={`${base}logos/${c.id}.svg`} alt="" width="40" height="40" />
          <span class="label">{c.label}</span>
          <span class="tagline">{c.tagline}</span>
          <span class="best-for">{c.bestFor}</span>
        </button>
      ))
    }
  </div>
</section>

<script>
  document.querySelectorAll<HTMLButtonElement>("[data-select-hero]").forEach((card) => {
    card.addEventListener("click", () => {
      document.querySelector<HTMLButtonElement>(`[data-cloud-btn="${card.dataset.cloudBtn}"]:not([data-select-hero])`)?.click();
    });
  });
</script>

<style>
  .selector-hero {
    padding: 3rem 0 2rem;
    text-align: center;
  }

  .selector-hero h1 {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    margin-bottom: 0.5rem;
  }

  .lede {
    color: var(--text-secondary);
    max-width: 38rem;
    margin: 0 auto 2rem;
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1rem;
  }

  .cloud-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.5rem 1rem;
    min-height: 44px;
    cursor: pointer;
    transition: transform var(--duration-micro) var(--ease-out), box-shadow var(--duration-micro) var(--ease-out);
  }

  .cloud-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
    border-color: var(--accent);
  }

  .cloud-card .label {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.1rem;
  }

  .cloud-card .tagline {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--accent-text, var(--accent));
  }

  .cloud-card .best-for {
    font-size: 0.75rem;
    color: var(--text-secondary);
  }
</style>
