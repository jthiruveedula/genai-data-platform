---
import { CLOUDS } from "../data/modules";
import Search from "./Search.astro";
const base = import.meta.env.BASE_URL;
---

<header class="navbar">
  <a class="brand" href={base}>
    <span class="brand-mark" aria-hidden="true"></span>
    GenAI Data Platform
  </a>
  <nav class="nav-links" aria-label="Primary">
    <a class="nav-link" href={`${base}#curriculum`}>Curriculum</a>
    <a class="nav-link" href={`${base}calculator/`}>Cost console</a>
    <a class="nav-link" href={`${base}matrix/`}>Matrix</a>
  </nav>

  <Search />

  <div class="flavor-switch" role="group" aria-label="Choose cloud flavor">
    {
      CLOUDS.map((c) => (
        <button type="button" class="flavor-btn" data-cloud-btn={c.id} aria-pressed="false" title={c.tagline}>
          <img src={`${base}logos/${c.id}.svg`} alt="" width="20" height="20" />
          <span>{c.label}</span>
        </button>
      ))
    }
  </div>

  <button type="button" id="theme-toggle" class="theme-toggle" aria-label="Toggle dark mode">
    <span aria-hidden="true">◐</span>
  </button>
</header>

<script>
  const root = document.documentElement;

  function setCloud(id: string) {
    root.setAttribute("data-cloud", id);
    localStorage.setItem("gdp.cloud", id);
    const url = new URL(location.href);
    url.searchParams.set("cloud", id);
    history.replaceState(null, "", url);
    document.querySelectorAll<HTMLButtonElement>("[data-cloud-btn]").forEach((btn) => {
      btn.setAttribute("aria-pressed", String(btn.dataset.cloudBtn === id));
    });
    // Scenes (hero canvas, architecture story, cost console) re-render their
    // cloud-aware pieces off this event; CSS-only labels use .cloud-swap.
    document.dispatchEvent(new CustomEvent("gdp:cloud-change", { detail: { cloud: id } }));
  }

  function bindCloudControls() {
    document.querySelectorAll<HTMLButtonElement>("[data-cloud-btn]").forEach((btn) => {
      if (btn.dataset.cloudBound) return;
      btn.dataset.cloudBound = "true";
      btn.addEventListener("click", () => setCloud(btn.dataset.cloudBtn!));
    });
    const current = root.getAttribute("data-cloud");
    if (current) setCloud(current);
  }

  bindCloudControls();
  document.addEventListener("astro:page-load", bindCloudControls);

  document.getElementById("theme-toggle")?.addEventListener("click", () => {
    const next = root.getAttribute("data-theme") === "dark" ? "light" : "dark";
    root.setAttribute("data-theme", next);
    localStorage.setItem("gdp.theme", next);
  });
</script>

<style>
  .navbar {
    position: sticky;
    top: 0;
    z-index: 50;
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.65rem 1.5rem;
    border-bottom: 1px solid var(--glass-border);
    /* Deliberately more opaque/blurred than --glass-bg/--glass-blur (the
       shared .glass-panel tokens used for occasional in-page cards): this
       bar is permanently visible and sticky over the hero's bright,
       saturated CTA button, which bled through as a distracting solid-color
       patch behind the brand/nav-links at 0.66 alpha + 14px blur. A
       one-off, sticky-nav-only override rather than raising the shared
       tokens (which would also change every .glass-panel card's look). */
    background: color-mix(in srgb, var(--glass-bg) 30%, var(--bg) 70%);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--font-heading);
    font-weight: 700;
    color: var(--text);
    text-decoration: none;
    margin-right: auto;
    letter-spacing: -0.01em;
  }

  .brand-mark {
    width: 9px;
    height: 9px;
    border-radius: 2px;
    background: var(--accent);
    box-shadow: 0 0 12px var(--accent);
    transition: background-color var(--duration-theme) var(--ease-out), box-shadow var(--duration-theme) var(--ease-out);
  }

  .nav-links {
    display: flex;
    gap: 0.25rem;
  }

  .nav-link {
    font-size: 0.85rem;
    color: var(--text-secondary);
    text-decoration: none;
    padding: 0.4rem 0.6rem;
    border-radius: var(--radius);
    transition: color var(--duration-micro) var(--ease-out), background-color var(--duration-micro) var(--ease-out);
  }

  .nav-link:hover {
    color: var(--text);
    background: var(--bg-raised);
  }

  .flavor-switch {
    display: flex;
    gap: 0.25rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 0.2rem;
    background: var(--bg-card);
  }

  .flavor-btn {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    background: transparent;
    border: none;
    border-radius: var(--radius);
    padding: 0.35rem 0.6rem;
    min-height: 32px;
    font-size: 0.8rem;
    color: var(--text-secondary);
    cursor: pointer;
    transition: background-color var(--duration-micro) var(--ease-out), color var(--duration-micro) var(--ease-out);
  }

  .flavor-btn:hover {
    background: var(--bg-raised);
    color: var(--text);
  }

  .flavor-btn[aria-pressed="true"] {
    background: var(--bg-raised);
    color: var(--text);
    box-shadow: inset 0 0 0 1.5px var(--accent);
  }

  .flavor-btn img {
    border-radius: 4px;
  }

  .theme-toggle {
    border: 1px solid var(--border);
    background: var(--bg-card);
    border-radius: var(--radius);
    width: 36px;
    height: 36px;
    cursor: pointer;
    color: var(--text);
    transition: border-color var(--duration-micro) var(--ease-out);
  }

  .theme-toggle:hover {
    border-color: var(--accent);
  }

  @media (max-width: 720px) {
    .navbar {
      flex-wrap: wrap;
      row-gap: 0.5rem;
      padding: 0.6rem 1rem;
    }
    .nav-links {
      order: 3;
    }
    .flavor-switch {
      order: 4;
      margin-left: auto;
    }
  }
</style>
