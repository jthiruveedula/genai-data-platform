{
  "ci": {
    "collect": {
      "startServerCommand": "npm run preview -- --port 4321",
      "startServerReadyPattern": "Local[\\s\\S]*?http://localhost:4321",
      "startServerReadyTimeout": 20000,
      "url": [
        "http://localhost:4321/genai-data-platform/",
        "http://localhost:4321/genai-data-platform/modules/45-evaluation/",
        "http://localhost:4321/genai-data-platform/calculator/"
      ],
      "numberOfRuns": 5
    },
    "assert": {
      "assertions": {
        "categories:accessibility": ["error", { "minScore": 0.95 }],
        "total-blocking-time": ["error", { "maxNumericValue": 700 }],
        "cumulative-layout-shift": ["error", { "maxNumericValue": 0.1 }],
        "render-blocking-resources": ["error", { "maxLength": 0 }],
        "categories:performance": ["warn", { "minScore": 0.95 }],
        "largest-contentful-paint": ["warn", { "maxNumericValue": 2500 }]
      }
    },
    "upload": {
      "target": "filesystem",
      "outputDir": "./.lighthouseci"
    }
  }
}
